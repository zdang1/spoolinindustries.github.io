-37.9a10.1 10.1 0 01-20.2 0h-37.9a10.1 10.1 0 01-20.2 0h-37.9a10.1 10.1 0 01-20.2 0h-38a10.1 10.1 0 01-20.2 0H1706a10.1 10.1 0 01-20.2 0h-37.9a10.1 10.1 0 01-20.2 0h-38a10.1 10.1 0 01-20.2 0h-37.9a10.1 10.1 0 01-20.2 0h-38a10.1 10.1 0 01-20.2 0h-37.9a10.1 10.1 0 01-20.2 0h-37.9a10.1 10.1 0 01-20.2 0h-37.9a10.1 10.1 0 01-20.3 0H1241a10.1 10.1 0 01-20.2 0h-38a10.1 10.1 0 01-20.2 0h-37.9a10.1 10.1 0 01-20.2 0h-37.9a10.1 10.1 0 01-20.2 0h-34.6V0z\" class=\"shape-fill\"></path><path d=\"M1956.3 44.8a10 10 0 01-10-10h20.2a10 10 0 01-10.2 10z\" opacity=\".3\" class=\"shape-fill\"></path><path d=\"M1956.3 44.8a10 10 0 01-10-10h20.2a10 10 0 01-10.2 10zM1956.3 24.8a10 10 0 0110.1 10h-20.2a10 10 0 0110.1-10z\" opacity=\".5\" class=\"shape-fill\"></path><path d=\"M1956.3 24.8a10 10 0 0110.1 10h-20.2a10 10 0 0110.1-10z\" opacity=\".3\" class=\"shape-fill\"></path><path d=\"M1956.3 24.8a10 10 0 0110.1 10h-20.2a10 10 0 0110.1-10z\" opacity=\".5\" class=\"shape-fill\"></path><path d=\"M1928.4 64.5a10.1 10.1 0 01-9.6-7h19.3a10.1 10.1 0 01-9.7 7zM1928.4 44.5a10 10 0 0110.2 10 10 10 0 01-.5 3h-19.3a9.7 9.7 0 01-.5-3 10 10 0 0110.1-10z\" opacity=\".3\" class=\"shape-fill\"></path><path d=\"M1928.4 44.5a10 10 0 0110.2 10 10 10 0 01-.5 3h-19.3a9.7 9.7 0 01-.5-3 10 10 0 0110.1-10zM1898.2 44.8a10 10 0 01-10.1-10h20.2a10 10 0 01-10.1 10z\" opacity=\".3\" class=\"shape-fill\"></path><path d=\"M1898.2 44.8a10 10 0 01-10.1-10h20.2a10 10 0 01-10.1 10zM1898.2 24.8a10 10 0 0110.1 10h-20.2a10 10 0 0110.1-10z\" opacity=\".5\" class=\"shape-fill\"></path><path d=\"M1898.2 24.8a10 10 0 0110.1 10h-20.2a10 10 0 0110.1-10z\" opacity=\".3\" class=\"shape-fill\"></path><path d=\"M1898.2 24.8a10 10 0 0110.1 10h-20.2a10 10 0 0110.1-10z\" opacity=\".5\" class=\"shape-fill\"></path><path d=\"M1870.3 64.5a10.1 10.1 0 01-9.6-7h19.2a10.1 10.1 0 01-9.6 7zM1870.3 44.5a10 10 0 019.6 13h-19.2a10 10 0 01-.5-3 10 10 0 0110.1-10z\" opacity=\".3\" class=\"shape-fill\"></path><path d=\"M1870.3 44.5a10 10 0 019.6 13h-19.2