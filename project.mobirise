=\".75\" d=\"M664.6 55.5L500 69.9 335.4 55.5 500 36l164.6 19.5z\" class=\"shape-fill\"></path><path opacity=\".5\" d=\"M1000 30.2V36L854.9 53.2 1000 65.9v9.8L779.3 56.4 1000 30.2z\" class=\"shape-fill\"></path><path opacity=\".5\" d=\"M1000 30.2V36L854.9 53.2 1000 65.9v9.8L779.3 56.4 1000 30.2z\" class=\"shape-fill\"></path><path opacity=\".5\" d=\"M1000 36v29.9L854.9 53.2 1000 36z\" class=\"shape-fill\"></path><path opacity=\".5\" d=\"M1000 36v29.9L854.9 53.2 1000 36z\" class=\"shape-fill\"></path><path opacity=\".75\" d=\"M1000 36v29.9L854.9 53.2 1000 36z\" class=\"shape-fill\"></path>\n</svg>\n    </div>\n</div>  \n    \n    \n    \n    \n    \n\n</section>",
          "_anchor": "patterns-29",
          "_cid": "uPo77Gfg7Z",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": "Barrys Dividers V3.00/components",
          "_isSecondary": true,
          "typeCompatible": "type",
          "_styles": {
            "padding-top": "45px",
            "padding-bottom": "(@paddingBottom * 15px)",
            "background-color": "@bgColor",
            "& when (@lineStyle = '1')": {
              ".custom-shape-divider": {
                "position": "absolute",
                "top": "0",
                "left": "0",
                "width": "100%",
                "overflow": "hidden",
                "line-height": "0"
              },
              ".custom-shape-divider svg": {
                "position": "relative",
                "display": "block",
                "width": "calc(100% + 1.3px)",
                "height": "40px",
                "& when (@divType = 'Tri04')": {
                  "height": "135px"
                },
                "& when (@divType = 'Tri03')": {
                  "transform": "rotateY(180deg)"
                }
              },
              ".custom-shape-divider .shape-fill": {
                "fill": "@lineColor",
                "& when (@blkShadow)": {
                  "filter": "drop-shadow(5px 5px 4px @shadowColor)"
                }
              }
            },
            "& when (@lineStyle = '2')": {
              ".custom-shape-divider": {
                "position": "absolute",
                "bottom": "0",
                "left": "0",
                "width": "100%",
                "overflow": "hidden",
                "line-height": "0",
                "transform": "rotate(180deg)"
              },
              ".custom-shape-divider svg": {
                "position": "relative",
                "display": "block",
                "width": "calc(100% + 1.3px)",
                "height": "40px",
                "& when (@divType = 'Tri04')": {
                  "height": "135px"
                },
                "& when (@divType = 'Tri03')": {
                  "transform": "rotateY(180deg)"
                }
              },
              ".custom-shape-divider .shape-fill": {
                "fill": "@lineColor",
                "& when (@blkShadow)": {
                  "filter": "drop-shadow(5px 5px 4px @shadowColor)"
                }
              }
            }
          },
          "_name": "triangles",
          "_sourceTheme": "neuralm5",
          "_customHTML": "<section mbr-id=\"_anchor\" class=\"_customHTML\">\n    \n    <mbr-parameters>\n    <!-- Block parameters controls (Blue \"Gear\" panel) -->\n        \n        <header>Select Divider</header>\n         <select title=\"Divider Type\" name=\"divType\">\n              <option value=\"Tri01\">Triangle 01</option>\n              <option value=\"Tri02\" selected>Triangle 02</option>\n              <option value=\"Tri03\">Triangle 03</option>\n              <option value=\"Tri04\">Triangle 04</option>\n              <option value=\"Tri05\">Triangle 05</option>\n         </select>\n        \n        <header>Divider Settings</header>\n        <input type=\"range\" inline title=\"Divider Height\" name=\"paddingBottom\" min=\"0\" max=\"8\" step=\"1\" value=\"3\">\n        <input type=\"color\" title=\"Background Color\" name=\"lineColor\" value=\"#121212\">\n        <input type=\"color\" title=\"Block Color\" name=\"bgColor\" value=\"#9f130f\">\n        \n         <select title=\"Line Style\" name=\"lineStyle\">\n           <option value=\"1\" selected>Top</option>\n           <option value=\"2\">Bottom</option>\n         </select>\n\t\t \n      <input type=\"checkbox\" title=\"Shadow\" name=\"blkShadow\" condition=\"divType !== 'Wave03'\">\n      <input type=\"color\" title=\"Shadow Color\" name=\"shadowColor\" value=\"#000000\" condition=\"blkShadow == '1'\">        \n        \n    <!-- End block parameters -->\n    </mbr-parameters> \n\n  \n<div mbr-if=\"divType == 'Tri01'\">        \n    <div class=\"custom-shape-divider\">\n    <svg data-name=\"Layer 1\" xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 1200 120\" preserveAspectRatio=\"none\">\n        <path d=\"M1200 0L0 0 598.97 114.72 1200 0z\" class=\"shape-fill\"></path>\n    </svg>\n    </div>\n</div>\n    \n    \n<div mbr-if=\"divType == 'Tri02'\">        \n    <div class=\"custom-shape-divider\">\n    <svg data-name=\"Layer 1\" xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 1200 120\" preserveAspectRatio=\"none\">\n        <path d=\"M1200 0L0 0 892.25 114.72 1200 0z\" class=\"shape-fill\"></path>\n    </svg>\n    </div>\n</div>\n    \n    \n<div mbr-if=\"divType == 'Tri03'\">        \n    <div class=\"custom-shape-divider\">\n    <svg data-name=\"Layer 1\" xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 1200 120\" preserveAspectRatio=\"none\">\n        <path d=\"M1200 0L0 0 892.25 114.72 1200 0z\" class=\"shape-fill\"></path>\n    </svg>\n    </div>\n</div>\n \n    \n<div mbr-if=\"divType == 'Tri04'\">        \n    <div class=\"custom-shape-divider\">\n    <svg xmlns=\"http://www.w3.org/2000/svg\" preserveAspectRatio=\"none\" viewBox=\"0 0 773.74 154.98\"><path class=\"shape-fill\" d=\"M0 0h773.74L386.87 77.5Z\"></path><path class=\"shape-fill\" d=\"m0 0 386.87 154.98L773.74 0Z\" opacity=\".66\"></path></svg>\n    </div>\n</div>  \n    \n\n<div mbr-if=\"divType == 'Tri05'\">        \n    <div class=\"custom-shape-divider\">\n    <svg data-name=\"Layer 1\" xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 1200 120\" preserveAspectRatio=\"none\">\n        <path d=\"M649.97 0L550.03 0 599.91 54.12 649.97 0z\" class=\"shape-fill\"></path>\n    </svg>\n    </div>\n</div>\n    \n\n</section>",
          "_cid": "uLsQG3sioc",
          "_anchor": "triangles-m",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": "Barrys Dividers V3.00/components",
          "typeCompatible": "type",
          "_isSecondary": true,
          "_styles": {
