        {
          "alias": "Barrys Lines V1.00/components",
          "_isSecondary": true,
          "typeCompatible": "type",
          "_styles": {
            "padding-top": "(@paddingTop * 15px)",
            "padding-bottom": "(@paddingBottom * 15px)",
            "background-color": "@bgColor",
            "hr": {
              "border": "0",
              "clear": "both",
              "display": "block",
              "margin": "0",
              "text-align": "center",
              "width": "(@SizeWidth * 1%)"
            },
            ".progress": {
              "background": "@Linecolor",
              "opacity": "@Opacity",
              "height": "(@CurThickness * 1px)",
              "overflow": "hidden",
              "position": "relative"
            },
            ".progress::before": {
              "animation-duration": "(@Speed * 1s)",
              "animation-timing-function": "ease",
              "animation-iteration-count": "infinite",
              "animation-name": "progress",
              "background": "@Progresscolor",
              "content": "\"\"",
              "display": "block",
              "height": "(@CurThickness * 1px)",
              "position": "absolute",
              "width": "100px"
            },
            "@keyframes progress": {
              "from": {
                "margin-left": "(@Start * 1%)",
                "width": "(@CursorSize * 1px)"
              },
              "to": {
                "margin-left": "(@Stop * 1%)",
                "width": "(@CursorSize * 1px)"
              }
            }
          },
          "_name": "animated",
          "_sourceTheme": "neuralm5",
          "_customHTML": "<section mbr-id=\"_anchor\" class=\"_customHTML\">\n\n    <mbr-parameters>\n        <!-- Block parameters controls (Blue \"Gear\" panel) -->\n      <header>Background</header> \n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"0\">\n      <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"0\">\n      <input type=\"color\" title=\"Background Color\" name=\"bgColor\" value=\"#121212\">\n    \n      <header>Line Color</header> \n       <input type=\"color\" title=\"Line Color\" name=\"Linecolor\" value=\"#9f130f\" selected>\n       <input type=\"color\" title=\"Progress Color\" name=\"Progresscolor\" value=\"#cb2723\" selected>\n      <input type=\"range\" inline title=\"Opacity\" name=\"Opacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.2\">\n        \n        <header>Animations</header>\n      <input type=\"range\" inline title=\"Cursor Length (px)\" name=\"CursorSize\" min=\"10\" max=\"200\" step=\"1\" value=\"200\">\n      <input type=\"range\" inline title=\"Thickness  (px)\" name=\"CurThickness\" min=\"1\" max=\"20\" step=\"1\" value=\"20\">\n      <input type=\"range\" inline title=\"Width (%)\" name=\"SizeWidth\" min=\"1\" max=\"98\" step=\"1\" value=\"97\">\n      <input type=\"range\" inline title=\"Speed (s)\" name=\"Speed\" min=\"0\" max=\"10\" step=\"1\" value=\"2\">\n       <input type=\"range\" inline title=\"Start (%)\" name=\"Start\" min=\"0\" max=\"49\" step=\"1\" value=\"0\">\n       <input type=\"range\" inline title=\"Stop (%)\" name=\"Stop\" min=\"49\" max=\"100\" step=\"1\" value=\"100\">\n     \n        <!-- <input type=\"range\" title=\"Spacing\" name=\"spacing\" min=\"0\" max=\"3\" step=\"0.1\" value=\"1\"> --\n        \n        <!-- End block parameters -->\n    </mbr-parameters>\n\n<div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\" style=\"min-width: 100%;\">\n       </div>\n\n     <div class=\"row justify-content-center\">\n              <hr class=\"progress\">\n\n </div>\n  \n</section>",
          "_cid": "uLJO1lrdZe",
          "_anchor": "animated-16",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "_name": "header1",
          "_sourceTheme": "gumm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"gymm5 header1\" group=\"Header\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"4\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"0\" condition=\"fullScreen == false\">\n        <input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showsubTitle\">\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\">\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\" checked>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/gumm5/components/_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#121212\" selected>\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@ADDONS_PATH@/gumm5/components/_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row justify-content-center\">\n            <div class=\"col-12 col-md-12 col-lg-12 col-xl-4\">\n                <h1 class=\"mbr-section-title mbr-fonts-style mb-4\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\"><b>Lock in your next upgrade with Spoolin Industries.</b></h1>\n            </div>\n            <div class=\"col-12 col-md-12 col-lg-12 col-xl-8\">\n                <div class=\"text-wrapper align-left\">\n                    <h2 class=\"mbr-section-subtitle mbr-fonts-style mb-2\" data-app-selector=\".mbr-section-subtitle\" mbr-theme-style=\"display-2\" mbr-if=\"showsubTitle\"><b>Lock in your next upgrade with Spoolin Industries.</b></h2>\n                    <p class=\"mbr-text align-left mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .mbr-section-btn\">LOREM IPSUM DOLOR SIT AMET CONSECTETUR\n                        ELIT<br></p>\n                    <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn align-left mt-5\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\"><a class=\"btn btn-primary\" href=\"index.html#custom-html-21\" data-app-placeholder=\"Type Text\">GET STARTED</a></div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            "@media (max-width: 1400px)": {
              ".col-lg-12": {
                "flex": "0 0 auto",
                "width": "100%"
              }
            },
            ".mbr-section-btn, .btn": {
              "width": "100%"
            },
            "& when (@reverseContent)": {
              ".row": {
                "flex-direction": "row-reverse"
              }
            },
            "@media (max-width: 991px)": {
              ".image-wrapper": {
                "margin-bottom": "1rem"
              }
            },
            ".row": {
              "align-items": "center"
            },
            ".image-wrapper": {
              "@media (max-width: 991px)": {
                "padding": "1.5rem"
              }
            },
            ".text-wrapper": {
              "@media (min-width: 992px)": {
                "padding": "0 2rem"
              }
            },
            ".mbr-section-title": {
              "color": "#ffffff",
              "text-align": "center"
            },
            ".mbr-text, .mbr-section-btn": {
              "color": "#ffffff"
            },
            ".mbr-section-subtitle": {
              "color": "#f7f7f7"
            }
          },
          "_cid": "uPlgmFNUXv",
          "_anchor": "header1-25",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": "Barrys Dividers V3.00/components",
          "_isSecondary": true,
          "typeCompatible": "type",
          "_styles": {
            "padding-top": "45px",
            "padding-bottom": "(@paddingBottom * 15px)",
            "background-color": "@bgColor",
            "& when (@lineStyle = '1')": {
              ".custom-shape-divider": {
                "position": "absolute",
                "top": "0",
                "left": "0",
                "width": "100%",
                "overflow": "hidden",
                "line-height": "0"
              },
              ".custom-shape-divider svg": {
                "position": "relative",
                "display": "block",
                "width": "calc(100% + 1.3px)",
                "height": "40px",
                "& when (@divType = 'Pat01')": {
                  "height": "80px"
                },
                "& when (@divType = 'Pat02')": {
                  "height": "60px"
                }
              },
              ".custom-shape-divider .shape-fill": {
                "fill": "@lineColor",
                "& when (@blkShadow)": {
                  "filter": "drop-shadow(5px 5px 4px @shadowColor)"
                }
              }
            },
            "& when (@lineStyle = '2')": {
              ".custom-shape-divider": {
                "position": "absolute",
                "bottom": "0",
                "left": "0",
                "width": "100%",
                "overflow": "hidden",
                "line-height": "0",
                "transform": "rotate(180deg)"
              },
              ".custom-shape-divider svg": {
                "position": "relative",
                "display": "block",
                "width": "calc(100% + 1.3px)",
                "height": "40px",
                "& when (@divType = 'Pat01')": {
                  "height": "80px"
                },
                "& when (@divType = 'Pat02')": {
                  "height": "60px"
                }
              },
              ".custom-shape-divider .shape-fill": {
                "fill": "@lineColor",
                "& when (@blkShadow)": {
                  "filter": "drop-shadow(5px 5px 4px @shadowColor)"
                }
              }
            }
          },
          "_name": "patterns",
          "_sourceTheme": "neuralm5",
          "_customHTML": "<section mbr-id=\"_anchor\" class=\"_customHTML\">\n    \n    <mbr-parameters>\n    <!-- Block parameters controls (Blue \"Gear\" panel) -->\n        \n        <header>Select Divider</header>\n         <select title=\"Divider Type\" name=\"divType\">\n              <option value=\"Pat01\" selected>Pattern 01</option>\n              <option value=\"Pat02\">Pattern 02</option>\n              <option value=\"Pat03\">Pattern 03</option>\n         </select>\n        \n        <header>Divider Settings</header>\n        <input type=\"range\" inline title=\"Divider Height\" name=\"paddingBottom\" min=\"0\" max=\"8\" step=\"1\" value=\"3\">\n        <input type=\"color\" title=\"Background Color\" name=\"lineColor\" value=\"#121212\">\n        <input type=\"color\" title=\"Block Color\" name=\"bgColor\" value=\"#121212\">\n        \n         <select title=\"Line Style\" name=\"lineStyle\">\n           <option value=\"1\" selected>Top</option>\n           <option value=\"2\">Bottom</option>\n         </select>\n\t\t \n      <input type=\"checkbox\" title=\"Shadow\" name=\"blkShadow\" condition=\"divType !== 'Wave03'\">\n      <input type=\"color\" title=\"Shadow Color\" name=\"shadowColor\" value=\"#000000\" condition=\"blkShadow == '1'\">        \n        \n    <!-- End block parameters -->\n    </mbr-parameters> \n\n<div mbr-if=\"divType == 'Wave01'\">     \n    <div class=\"custom-shape-divider\">\n    <svg data-name=\"Layer 1\" xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 1200 120\" preserveAspectRatio=\"none\">\n        <path d=\"M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V0H0V27.35A600.21,600.21,0,0,0,321.39,56.44Z\" class=\"shape-fill\"></path>\n    </svg>\n    </div>\n</div>\n    \n    \n<div mbr-if=\"divType == 'Pat01'\">        \n    <div class=\"custom-shape-divider\">\n    <svg preserveAspectRatio=\"xMidYMax slice\" xmlns=\"http: