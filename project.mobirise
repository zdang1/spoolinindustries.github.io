            "background-color": "@bgColor",
            "& when (@lineStyle = '1')": {
              ".custom-shape-divider": {
                "position": "absolute",
                "top": "0",
                "left": "0",
                "width": "100%",
                "overflow": "hidden",
                "line-height": "0"
              },
              ".custom-shape-divider svg": {
                "position": "relative",
                "display": "block",
                "width": "calc(100% + 1.3px)",
                "height": "40px",
                "& when (@divType = 'Tri04')": {
                  "height": "135px"
                },
                "& when (@divType = 'Tri03')": {
                  "transform": "rotateY(180deg)"
                }
              },
              ".custom-shape-divider .shape-fill": {
                "fill": "@lineColor",
                "& when (@blkShadow)": {
                  "filter": "drop-shadow(5px 5px 4px @shadowColor)"
                }
              }
            },
            "& when (@lineStyle = '2')": {
              ".custom-shape-divider": {
                "position": "absolute",
                "bottom": "0",
                "left": "0",
                "width": "100%",
                "overflow": "hidden",
                "line-height": "0",
                "transform": "rotate(180deg)"
              },
              ".custom-shape-divider svg": {
                "position": "relative",
                "display": "block",
                "width": "calc(100% + 1.3px)",
                "height": "40px",
                "& when (@divType = 'Tri04')": {
                  "height": "135px"
                },
                "& when (@divType = 'Tri03')": {
                  "transform": "rotateY(180deg)"
                }
              },
              ".custom-shape-divider .shape-fill": {
