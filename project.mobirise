=\".75\" d=\"M664.6 55.5L500 69.9 335.4 55.5 500 36l164.6 19.5z\" class=\"shape-fill\"></path><path opacity=\".5\" d=\"M1000 30.2V36L854.9 53.2 1000 65.9v9.8L779.3 56.4 1000 30.2z\" class=\"shape-fill\"></path><path opacity=\".5\" d=\"M1000 30.2V36L854.9 53.2 1000 65.9v9.8L779.3 56.4 1000 30.2z\" class=\"shape-fill\"></path><path opacity=\".5\" d=\"M1000 36v29.9L854.9 53.2 1000 36z\" class=\"shape-fill\"></path><path opacity=\".5\" d=\"M1000 36v29.9L854.9 53.2 1000 36z\" class=\"shape-fill\"></path><path opacity=\".75\" d=\"M1000 36v29.9L854.9 53.2 1000 36z\" class=\"shape-fill\"></path>\n</svg>\n    </div>\n</div>  \n    \n    \n    \n    \n    \n\n</section>",
          "_anchor": "patterns-28",
          "_cid": "uPo757BAQF",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "_customTemplate": true,
          "_afterNavbarItem": false,
          "_customHTML": "\n\n\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Professional Tuning Services - Tuned by Chop</title>\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin=\"\">\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&amp;display=swap\" rel=\"stylesheet\">\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            font-family: 'Inter', 'Segoe UI', system-ui, -apple-system, sans-serif;\n            background: #121212;\n            color: #ffffff;\n            min-height: 100vh;\n            padding: 0;\n            margin: 0;\n            overflow-x: hidden;\n        }\n\n        .tuning-block {\n            max-width: 1200px;\n            margin: 0 auto;\n            background: linear-gradient(145deg, #111111, #0a0a0a);\n            border-radius: 24px;\n            box-shadow: 0 32px 64px rgba(0, 0, 0, 0.8), \n                        0 0 0 1px rgba(159, 19, 15, 0.1);\n            overflow: hidden;\n            position: relative;\n            backdrop-filter: blur(20px);\n        }\n\n        .tuning-block::before {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            right: 0;\n            bottom: 0;\n            background: linear-gradient(135deg, \n                rgba(159, 19, 15, 0.05) 0%, \n                transparent 30%, \n                transparent 70%, \n                rgba(159, 19, 15, 0.05) 100%);\n            pointer-events: none;\n        }\n\n        .tuning-content {\n            padding: 80px 60px;\n            text-align: center;\n            position: relative;\n            z-index: 2;\n        }\n\n\n\n        .tuning-title {\n            font-size: 3.2rem;\n            font-weight: 800;\n            margin-bottom: 24px;\n            background: linear-gradient(135deg, #ffffff, #cccccc);\n            -webkit-background-clip: text;\n            -webkit-text-fill-color: transparent;\n            background-clip: text;\n            line-height: 1.2;\n        }\n\n        .tuning-subtitle {\n            font-size: 1.4rem;\n            color: #9f130f;\n            font-weight: 600;\n            margin-bottom: 32px;\n            text-transform: uppercase;\n            letter-spacing: 2px;\n        }\n\n        .tuning-description {\n            font-size: 1.2rem;\n            line-height: 1.8;\n            color: rgba(255, 255, 255, 0.8);\n            margin-bottom: 50px;\n            max-width: 800px;\n            margin-left: auto;\n            margin-right: auto;\n        }\n\n        .features-grid {\n            display: grid;\n            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));\n            gap: 30px;\n            margin: 60px 0;\n        }\n\n        .feature-item {\n            background: linear-gradient(145deg, #161616, #0e0e0e);\n            border: 1px solid rgba(255, 255, 255, 0.08);\n            border-radius: 16px;\n            padding: 30px 25px;\n            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n            position: relative;\n            overflow: hidden;\n        }\n\n        .feature-item::before {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            right: 0;\n            bottom: 0;\n            background: linear-gradient(135deg, \n                rgba(159, 19, 15, 0.1) 0%, \n                transparent 50%, \n                rgba(159, 19, 15, 0.1) 100%);\n            opacity: 0;\n            transition: opacity 0.4s ease;\n        }\n\n        .feature-item:hover {\n            transform: translateY(-8px);\n            border-color: rgba(159, 19, 15, 0.3);\n            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);\n        }\n\n        .feature-item:hover::before {\n            opacity: 1;\n        }\n\n        .feature-icon {\n            font-size: 2.5rem;\n            margin-bottom: 20px;\n            color: #9f130f;\n        }\n\n        .feature-title {\n            font-size: 1.1rem;\n            font-weight: 700;\n            margin-bottom: 12px;\n            color: #ffffff;\n        }\n\n        .feature-text {\n            font-size: 0.95rem;\n            color: rgba(255, 255, 255, 0.7);\n            line-height: 1.5;\n        }\n\n        .cta-button {\n            display: inline-flex;\n            align-items: center;\n            gap: 15px;\n            padding: 20px 40px;\n            background: linear-gradient(135deg, #9f130f 0%, #c71610 50%, #9f130f 100%);\n            color: white;\n            text-decoration: none;\n            border-radius: 16px;\n            font-size: 1.2rem;\n            font-weight: 700;\n            text-transform: uppercase;\n            letter-spacing: 1px;\n            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n            position: relative;\n            overflow: hidden;\n            border: 2px solid rgba(199, 22, 16, 0.3);\n            box-shadow: 0 8px 32px rgba(159, 19, 15, 0.3);\n        }\n\n        .cta-button::before {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: -100%;\n            width: 100%;\n            height: 100%;\n            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);\n            transition: left 0.5s ease;\n        }\n\n        .cta-button:hover::before {\n            left: 100%;\n        }\n\n        .cta-button:hover {\n            transform: translateY(-4px) scale(1.05);\n            box-shadow: \n                0 20px 50px rgba(159, 19, 15, 0.5),\n                0 0 0 3px rgba(199, 22, 16, 0.3);\n        }\n\n        .cta-button:active {\n            transform: translateY(-2px) scale(1.02);\n        }\n\n        .arrow-icon {\n            font-size: 1.5rem;\n            transition: transform 0.3s ease;\n        }\n\n        .cta-button:hover .arrow-icon {\n            transform: translateX(5px);\n        }\n\n        .info-text {\n            margin-top: 30px;\n            font-size: 0.95rem;\n            color: rgba(255, 255, 255, 0.6);\n            font-style: italic;\n        }\n\n        .powered-by {\n            margin-top: 40px;\n            padding-top: 30px;\n            border-top: 1px solid rgba(255, 255, 255, 0.1);\n            font-size: 0.9rem;\n            color: rgba(255, 255, 255, 0.5);\n        }\n\n        .countdown-timer {\n            display: none;\n            margin-top: 20px;\n            font-size: 1.1rem;\n            color: #9f130f;\n            font-weight: 600;\n        }\n\n        @media (max-width: 768px) {\n            .tuning-content {\n                padding: 40px 30px;\n            }\n            \n            .tuning-title {\n                font-size: 2.2rem;\n            }\n            \n            .tuning-subtitle {\n                font-size: 1.1rem;\n            }\n            \n            .features-grid {\n                grid-template-columns: 1fr;\n                gap: 20px;\n                margin: 40px 0;\n            }\n            \n            .cta-button {\n                padding: 18px 35px;\n                font-size: 1.1rem;\n            }\n        }\n\n        @media (max-width: 480px) {\n            .tuning-block {\n                margin: 10px;\n                border-radius: 15px;\n            }\n            \n            .tuning-content {\n                padding: 30px 20px;\n            }\n            \n            .tuning-title {\n                font-size: 1.8rem;\n            }\n        }\n\n        /* Smooth page transition */\n        .page-transition {\n            position: fixed;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            background: linear-gradient(45deg, #9f130f, #c71610);\n            z-index: 9999;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            opacity: 0;\n            visibility: hidden;\n            transition: all 0.5s ease;\n        }\n\n        .page-transition.active {\n            opacity: 1;\n            visibility: visible;\n        }\n\n        .transition-text {\n            color: white;\n            font-size: 1.5rem;\n            font-weight: 700;\n            text-align: center;\n        }\n    </style>\n\n\n    <div class=\"page-transition\" id=\"pageTransition\">\n        <div class=\"transition-text\">\n            <div>Redirecting to Tuned by Chop...</div>\n            <div class=\"countdown-timer\" id=\"countdownTimer\">3</div>\n        </div>\n    </div>\n\n    <div class=\"tuning-block\">\n        <div class=\"tuning-content\">\n            <h1 class=\"tuning-title\">Need Professional Tuning?</h1>\n            <div class=\"tuning-subtitle\">Unlock Your Engine's True Potential</div>\n            \n            <p class=\"tuning-description\">\n                Your custom fabrication is just the beginning. Take your build to the next level with professional \n                ECU tuning and optimization services from our trusted partners at Tuned by Chop.\n            </p>\n\n            <div class=\"features-grid\">\n                <div class=\"feature-item\">\n                    <div class=\"feature-icon\">⚡</div>\n                    <div class=\"feature-title\">ECU Tuning</div>\n                    <div class=\"feature-text\">Professional engine mapping and optimization for maximum performance</div>\n                </div>\n                <div class=\"feature-item\">\n                    <div class=\"feature-icon\">🔧</div>\n                    <div class=\"feature-title\">Dyno Services</div>\n                    <div class=\"feature-text\">Precision power measurement and tuning on state-of-the-art equipment</div>\n                </div>\n                <div class=\"feature-item\">\n                    <div class=\"feature-icon\">📊</div>\n                    <div class=\"feature-title\">Data Logging</div>\n                    <div class=\"feature-text\">Comprehensive monitoring and analysis for optimal engine health</div>\n                </div>\n            </div>\n\n            <a href=\"#\" class=\"cta-button\" id=\"tunedByChopBtn\">\n                Visit Tuned by Chop\n                <span class=\"arrow-icon\">→</span>\n            </a>\n\n            <div class=\"info-text\">\n                Professional tuning services to complement your custom fabrication work\n            </div>\n\n            <div class=\"powered-by\">\n                Trusted partner of Spoolin Industries\n            </div>\n        </div>\n    </div>\n\n    [JS_CODE_0]\n\n ",
          "_customCSS": "",
          "alias": "code-editor",
          "_tags": [
            "Extension"
          ],
          "_name": "pro.custom-html",
          "_sourceTheme": "neuralm5",
          "_anchor": "custom-html-26",
          "_PHPplaceholders": [],
          "_JSplaceholders": [
            "<script>\n        document.getElementById('tunedByChopBtn').addEventListener('click', function(e) {\n            e.preventDefault();\n            \n            // Show transition overlay\n            const transition = document.getElementById('pageTransition');\n            const countdown = document.getElementById('countdownTimer');\n            \n            transition.classList.add('active');\n            countdown.style.display = 'block';\n            \n            // Countdown animation\n            let count = 3;\n            const countdownInterval = setInterval(() => {\n                count--;\n                countdown.textContent = count;\n                \n                if (count <= 0) {\n                    clearInterval(countdownInterval);\n                    // Redirect to the actual website\n                    window.open('https://tunedbychop.com.au', '_blank');\n                    \n                    // Hide transition after redirect\n                    setTimeout(() => {\n                        transition.classList.remove('active');\n                        countdown.style.display = 'none';\n                        countdown.textContent = '3';\n                    }, 500);\n                }\n            }, 1000);\n        });\n\n        // Add hover effects and animations\n        document.querySelectorAll('.feature-item').forEach(item => {\n            item.addEventListener('mouseenter', function() {\n                this.style.transform = 'translateY(-8px) scale(1.02)';\n            });\n            \n            item.addEventListener('mouseleave', function() {\n                this.style.transform = 'translateY(0) scale(1)';\n            });\n        });\n\n        // Add page load animation\n        document.addEventListener('DOMContentLoaded', function() {\n            const block = document.querySelector('.tuning-block');\n            block.style.opacity = '0';\n            block.style.transform = 'translateY(30px)';\n            \n            setTimeout(() => {\n                block.style.transition = 'all 0.8s cubic-bezier(0.4, 0, 0.2, 1)';\n                block.style.opacity = '1';\n                block.style.transform = 'translateY(0)';\n            }, 100);\n        });\n\n        // Optional: Auto-redirect after 30 seconds if user doesn't click\n        // setTimeout(() => {\n        //     document.getElementById('tunedByChopBtn').click();\n        // }, 30000);\n    </script>"
          ]
        },
        {
          "alias": "Barrys Dividers V3.00/components",
          "_isSecondary": true,
          "typeCompatible": "type",
          "_styles": {
            "padding-top": "45px",
            "padding-bottom": "(@paddingBottom * 15px)",
            "background-color": "@bgColor",
            "& when (@lineStyle = '1')": {
              ".custom-shape-divider": {
                "position": "absolute",
                "top": "0",
                "left": "0",
                "width": "100%",
                "overflow": "hidden",
                "line-height": "0"
              },
              ".custom-shape-divider svg": {
                "position": "relative",
                "display": "block",
                "width": "calc(100% + 1.3px)",
                "height": "40px",
                "& when (@divType = 'Pat01')": {
                  "height": "80px"
                },
                "& when (@divType = 'Pat02')": {
                  "height": "60px"
                }
              },
              ".custom-shape-divider .shape-fill": {
                "fill": "@lineColor",
                "& when (@blkShadow)": {
                  "filter": "drop-shadow(5px 5px 4px @shadowColor)"
                }
              }
            },
            "& when (@lineStyle = '2')": {
              ".custom-shape-divider": {
                "position": "absolute",
                "bottom": "0",
                "left": "0",
                "width": "100%",
                "overflow": "hidden",
                "line-height": "0",
                "transform": "rotate(180deg)"
              },
              ".custom-shape-divider svg": {
                "position": "relative",
                "display": "block",
                "width": "calc(100% + 1.3px)",
                "height": "40px",
                "& when (@divType = 'Pat01')": {
                  "height": "80px"
                },
                "& when (@divType = 'Pat02')": {
                  "height": "60px"
                }
              },
              ".custom-shape-divider .shape-fill": {
                "fill": "@lineColor",
                "& when (@blkShadow)": {
                  "filter": "drop-shadow(5px 5px 4px @shadowColor)"
                }
              }
            }
          },
          "_name": "patterns",
          "_sourceTheme": "neuralm5",
          "_customHTML": "<section mbr-id=\"_anchor\" class=\"_customHTML\">\n    \n    <mbr-parameters>\n    <!-- Block parameters controls (Blue \"Gear\" panel) -->\n        \n        <header>Select Divider</header>\n         <select title=\"Divider Type\" name=\"divType\">\n              <option value=\"Pat01\" selected>Pattern 01</option>\n              <option value=\"Pat02\">Pattern 02</option>\n              <option value=\"Pat03\">Pattern 03</option>\n         </select>\n        \n        <header>Divider Settings</header>\n        <input type=\"range\" inline title=\"Divider Height\" name=\"paddingBottom\" min=\"0\" max=\"8\" step=\"1\" value=\"3\">\n        <input type=\"color\" title=\"Background Color\" name=\"lineColor\" value=\"#121212\">\n        <input type=\"color\" title=\"Block Color\" name=\"bgColor\" value=\"#121212\">\n        \n         <select title=\"Line Style\" name=\"lineStyle\">\n           <option value=\"1\" selected>Top</option>\n           <option value=\"2\">Bottom</option>\n         </select>\n\t\t \n      <input type=\"checkbox\" title=\"Shadow\" name=\"blkShadow\" condition=\"divType !== 'Wave03'\">\n      <input type=\"color\" title=\"Shadow Color\" name=\"shadowColor\" value=\"#000000\" condition=\"blkShadow == '1'\">        \n        \n    <!-- End block parameters -->\n    </mbr-parameters> \n\n<div mbr-if=\"divType == 'Wave01'\">     \n    <div class=\"custom-shape-divider\">\n    <svg data-name=\"Layer 1\" xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 1200 120\" preserveAspectRatio=\"none\">\n        <path d=\"M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V0H0V27.35A600.21,600.21,0,0,0,321.39,56.44Z\" class=\"shape-fill\"></path>\n    </svg>\n    </div>\n</div>\n    \n    \n<div mbr-if=\"divType == 'Pat01'\">        \n    <div class=\"custom-shape-divider\">\n    <svg preserveAspectRatio=\"xMidYMax slice\" xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 2000 60\"><path opacity=\".5\" d=\"M32 32H15L6 17l9-15h17l9 15-9 15z\" class=\"shape-fill\"></path><path opacity=\".5\" d=\"M64 32H47l-9-15 9-15h17l9 15-9 15zM49 53h-7l-4-7 4-7h7l4 7-4 7zM5 35H3l-2-2 2-2h2l1 2-1 2z\" class=\"shape-fill\"></path><path opacity=\".2\" d=\"M28 43h-8l-4-7 4-7h8l4 7-4 7zm3 6h-1l-1-1 1-1h1l1 1-1 1zm-18-1H8l-3-4 3-5h5l3 5-3 4zm-3-18H5l-3-5 3-4h5l2 4-2 5zm31 8h-3l-1-3 1-2h3l1 2-1 3zm-2-9h-4l-1-3 1-3h4l1 3-1 3zM24 52h-3l-2-2 2-3h3l1 3-1 2z\" class=\"shape-fill\"></path><path opacity=\".5\" d=\"M87 35h2l1-2-1-2h-2l-2 2 2 2z\" class=\"shape-fill\"></path><path opacity=\".2\" d=\"M64 43h8l4-7-4-7h-8l-4 7 4 7zm-3 6h1l1-1-1-1h-1l-1 1 1 1zm17-1h6l3-4-3-5h-6l-2 5 2 4z\" class=\"shape-fill\"></path><path opacity=\".5\" d=\"M82 30h5l2-5-2-4h-5l-3 4 3 5z\" class=\"shape-fill\"></path><path opacity=\".2\" d=\"M51 38h3l1-3-1-2h-3l-2 2 2 3zm2-9h3l2-3-2-3h-3l-2 3 2 3zm15 23h3l1-2-1-3h-3l-1 3 1 2z\" class=\"shape-fill\"></path><path opacity=\".5\" d=\"M125 32h-18l-8-15 8-15h18l9 15-9 15z\" class=\"shape-fill\"></path><path opacity=\".5\" d=\"M156 32h-17l-9-15 9-15h17l9 15-9 15zm-14 21h-8l-4-7 4-7h8l3 7-3 7zM97 35h-2l-1-2 1-2h2l2 2-2 2z\" class=\"shape-fill\"></path><path opacity=\".2\" d=\"M120 43h-8l-4-7 4-7h8l4 7-4 7zm3 6h-1l-1-1 1-1h1l1 1-1 1zm-17-1h-6l-3-4 3-5h6l2 5-2 4zm-4-18h-5l-2-5 2-4h5l3 4-3 5zm31 8h-3l-1-3 1-2h3l2 2-2 3zm-2-9h-3l-2-3 2-3h3l2 3-2 3zm-15 23h-3l-1-2 1-3h3l2 3-2 2z\" class=\"shape-fill\"></path><path opacity=\".5\" d=\"M179 35h2l2-2-2-2h-2l-1 2 1 2z\" class=\"shape-fill\"></path><path opacity=\".2\" d=\"M156 43h8l4-7-4-7h-8l-4 7 4 7zm-3 6h1l1-1-1-1h-1v2zm18-1h5l3-4-3-5h-5l-3 5 3 4z\" class=\"shape-fill\"></path><path opacity=\".5\" d=\"M174 30h5l3-5-3-4h-5l-2 4 2 5z\" class=\"shape-fill\"></path><path opacity=\".2\" d=\"M143 38h3l2-3-2-2h-3l-1 2 1 3zm2-9h4l1-3-1-3h-4l-1 3 1 3zm15 23h3l2-2-2-3h-3l-1 3 1 2z\" class=\"shape-fill\"></path><path opacity=\".5\" d=\"M217 32h-17l-9-15 9-15h17l9 15-9 15z\"