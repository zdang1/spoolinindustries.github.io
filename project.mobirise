          },
          "_name": "menu01",
          "_sourceTheme": "neuralm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"menu menu01 neuralm5\" group=\"Menu\" plugins=\"DropDown, TouchSwipe\" always-top global once=\"menu\" not-draggable position-absolute>\n    <mbr-parameters>\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"checkbox\" title=\"Logo\" name=\"showLogo\" checked>\n        <input type=\"range\" title=\"Logo Size\" inline name=\"logoSize\" min=\"3\" max=\"8\" step=\"0.1\" value=\"5.4\" condition=\"showLogo\">\n        <input type=\"checkbox\" title=\"Brand Name\" name=\"showBrand\">\n        <input type=\"checkbox\" title=\"Menu Items\" name=\"showItems\" checked>\n        <input type=\"color\" title=\"Active Color\" name=\"activeColor\" value=\"#121212\" condition=\"showItems\">\n        <input type=\"color\" title=\"Active BG\" name=\"activeBg\" value=\"#ffffff\" condition=\"showItems\">\n        <input type=\"checkbox\" title=\"Icons\" name=\"showIcons\" checked>\n        <select title=\"Amount\" name=\"iconsAmount\" condition=\"showIcons\">\n            <option value=\"1\">1</option>\n            <option value=\"2\" selected>2</option>\n            <option value=\"3\">3</option>\n            <option value=\"4\">4</option>\n        </select>\n        <input type=\"color\" title=\"Icons Color\" name=\"iconsColor\" value=\"#ffffff\" condition=\"showIcons\">\n        <header>Buttons</header>\n        <input type=\"checkbox\" title=\"Button\" name=\"showButtons\" checked>\n        <input type=\"color\" title=\"Button Gradient 1\" value=\"#9f130f\" name=\"gradient_1\" condition=\"showButtons\" selected>\n        <input type=\"color\" title=\"Button Gradient 2\" value=\"#000000\" name=\"gradient_2\" condition=\"showButtons\" selected>\n        <input type=\"color\" title=\"Button Active Color\" value=\"#ffffff\" name=\"activeBtn\" condition=\"showButtons\" selected>\n        <header>Styles</header>\n        <input type=\"checkbox\" title=\"Sticky\" name=\"sticky\" checked>\n        <input type=\"checkbox\" title=\"Collapsed\" name=\"collapsed\">\n        <input type=\"checkbox\" title=\"Transparent\" name=\"transparent\" checked>\n        <input type=\"range\" title=\"Opacity\" name=\"opacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.2\" condition=\"transparent\">\n        <input type=\"color\" title=\"Color\" name=\"menuBgColor\" value=\"#121212\">\n        <input type=\"color\" title=\"Hamburger\" name=\"hamburgerColor\" value=\"#ffffff\">\n    </mbr-parameters>\n\n    <nav class=\"navbar navbar-dropdown\" mbr-class=\"{'navbar-fixed-top':sticky,\n                     'navbar-expand-lg':!collapsed,\n                     'collapsed':collapsed}\">\n        <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\" class=\"content-wrap\">\n            <div class=\"navbar-brand\">\n                <span mbr-if=\"showLogo\" class=\"navbar-logo\">\n                    <a href=\"index.html#aheader1-6\">\n                        <img src=\"@PROJECT_PATH@/assets/images/e564d451be837b57-1192x710.png-108x64.png\" alt=\"Spoolin Industries Logo\" mbr-style=\"{'height': logoSize + 'rem'}\">\n                    </a>\n                </span>\n                <span mbr-if=\"showBrand\" mbr-buttons mbr-theme-style=\"display-7\" class=\"navbar-caption-wrap\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd,-mbrBtnRemove,-iconFont\"><a class=\"navbar-caption text-white\" data-app-selector=\".navbar-caption\" href=\"@THEME_PATH@/components/index.html\" data-app-placeholder=\"Type Text\">MA</a></span>\n            </div>\n            <button class=\"navbar-toggler\" type=\"button\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-target=\"#navbarSupportedContent\" data-bs-target=\"#navbarSupportedContent\" aria-controls=\"navbarNavAltMarkup\" aria-expanded=\"false\" aria-label=\"Toggle navigation\" mbr-if=\"showItems || showIcons || showButtons\">\n                <div class=\"hamburger\">\n                    <span></span>\n                    <span></span>\n                    <span></span>\n                    <span></span>\n                </div>\n            </button>\n            <div class=\"collapse navbar-collapse\" id=\"navbarSupportedContent\" mbr-if=\"showItems || showIcons || showButtons\">\n                <ul mbr-menu class=\"navbar-nav nav-dropdown\" mbr-theme-style=\"display-4\" mbr-if=\"showItems\" mbr-class=\"{'nav-right': !showButtons,'navbar-nav-top-padding': isPublish && !showBrand && !showLogo}\"><li class=\"nav-item\"><a class=\"nav-link link text-white text-primary\" href=\"index.html#aheader1-6\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\"><strong>HOME</strong></a></li>\n                    <li class=\"nav-item\"><a class=\"nav-link link text-white text-primary\" href=\"index.html#custom-html-21\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\"><strong>SERVICES</strong></a>\n                    </li><li class=\"nav-item\"><a class=\"nav-link link text-white text-primary\" href=\"index.html#features07-1c\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\"><strong>TEAM</strong></a>\n                    </li><li class=\"nav-item\"><a class=\"nav-link link text-white text-primary\" href=\"index.html#list01-15\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\"><strong>FAQ</strong></a></li><li class=\"nav-item\"><a class=\"nav-link link text-white text-primary\" href=\"index.html#contacts01-14\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\"><strong>CONTACT US</strong></a></li><li class=\"nav-item\"><a class=\"nav-link link text-white text-primary\" href=\"index.html#slider1-1z\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\"><strong>OUR WORK</strong><strong><br></strong></a></li></ul>\n                <div class=\"icons-menu\" mbr-if=\"showIcons\">\n                    <a class=\"iconfont-wrapper\" href=\"https://www.facebook.com/people/Spoolin-Industries/61557442715086/\" target=\"_blank\">\n                        <span mbr-icon class=\"p-2 mbr-iconfont socicon-facebook socicon\"></span>\n                    </a>\n                    <a class=\"iconfont-wrapper\" href=\"https://www.tiktok.com/@spoolinindustries\" target=\"_blank\" mbr-if=\"iconsAmount > 1\">\n                        <span mbr-icon class=\"p-2 mbr-iconfont socicon-tiktok socicon\"></span>\n                    </a>\n                    <a class=\"iconfont-wrapper\" href=\"https://mobiri.se\" target=\"_blank\" mbr-if=\"iconsAmount > 2\">\n                        <span mbr-icon class=\"p-2 mbr-iconfont socicon-instagram socicon\"></span>\n                    </a>\n                    <a class=\"iconfont-wrapper\" href=\"https://mobiri.se\" target=\"_blank\" mbr-if=\"iconsAmount > 3\">\n                        <span mbr-icon class=\"p-2 mbr-iconfont socicon-linkedin socicon\"></span>\n                    </a>\n                </div>\n                <div mbr-if=\"showButtons\" mbr-buttons mbr-theme-style=\"display-4\" class=\"navbar-buttons mbr-section-btn\"><a class=\"btn btn-white-outline\" href=\"index.html#aform1-x\" data-app-placeholder=\"Type Text\">Book a Build</a></div>\n            </div>\n        </div>\n    </nav>\n</section>",
          "_cid": "uGKLfvQrfz",
          "_anchor": "menu01-t",
          "_PHPplaceholders": [],
          "_JSplaceholders": [],
          "_protectedParams": [],
          "_global": true,
          "_once": "menu",
          "_params": {}
        },
        {
          "_name": "aheader1",
          "_sourceTheme": "systemm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"header1\" group=\"Headers\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" plugins=\"VimeoPlayer\" mbr-class=\"{'mbr-fullscreen': fullScreen,'mbr-parallax-background' :bg.parallax}\">\n\n    <mbr-parameters>\n        <!-- Block parameters controls (Blue \"Gear\" panel) -->\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"8\" step=\"1\" value=\"6\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"8\" step=\"1\" value=\"6\" condition=\"fullScreen == false\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Colored Text\" name=\"showColoredText\" condition=\"showTitle\" checked>\n        <input type=\"color\" title=\"Colored Text Color\" name=\"coloredText\" value=\"#EE2524\" condition=\"showTitle && showColoredText\">\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\">\n        <input type=\"checkbox\" title=\"Icon\" name=\"showIcon\">\n        <input type=\"color\" title=\"Icon Hover BG\" name=\"iconBg\" value=\"#f0f0f0\" condition=\"showIcon\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@PROJECT_PATH@/assets/images/spooling-industries-landing-page.png-1536x1024.png\" parallax>\n            <input type=\"color\" title=\"Color\" value=\"#fbfbfb\">\n            <input type=\"video\" title=\"Video\" value=\"https://player.vimeo.com/video/1086027271?h=6e44773b52\" selected>\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@PROJECT_PATH@/assets/images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#fbfbfb\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.5\" condition=\"overlay && bg.type !== 'color'\">\n        <!-- End block parameters -->\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n    </div>\n\n    <div class=\"container\">\n        <div class=\"media-container\">\n            <div class=\"col-md-12\">\n                <div class=\"row\">\n                    <div class=\"text-container col-12\">\n                        <h1 class=\"mbr-section-title mbr-white mbr-bold align-left mbr-fonts-style mb-3\" mbr-theme-style=\"display-1\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title\">FORGED <br>FABRICATION,<br><font color=\"#ee2524\">BOOSTED&nbsp;<br></font>PERFORMANCE.\n                        </h1>\n                        <p class=\"mbr-text mbr-white align-left mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .mbr-section-btn\"><i><b>\n                            Custom turbo systems, flawless welds, and dyno-proven tuning—engineered by Spoolin Industries to unleash your ride.\n                        </b></i></p>\n                        <div class=\"mbr-section-btn align-left\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\" mbr-buttons mbr-theme-style=\"display-7\">\n                            <a class=\"btn btn-black\" href=\"https://mobiri.se/\">\n                                <div class=\"btn-transform\">\n                                    <div class=\"btn-transform-1\">LEARN MORE</div>\n                                </div>\n                                </a>\n                        </div>\n                    </div>\n                    <div class=\"card-col\">\n                        <div class=\"card-wrapper\" mbr-if=\"showIcon\">\n                            <div class=\"card-box\">\n                                <div class=\"bg-hover\"></div>\n                                <div class=\"item-img\">\n                                    <img src=\"@ADDONS_PATH@/systemm5/components/_images/features/features1.svg\" alt=\"Mobirise Website Builder\">\n                                </div>\n                                <span mbr-icon class=\"mbr-iconfont mobi-mbri-right mobi-mbri\"></span>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 15px)",
              "padding-bottom": "(@paddingBottom * 15px)"
            },
            "& when (@bg-type = \"color\")": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = \"image\")": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".row": {
              "display": "flex",
              "flex-wrap": "nowrap",
              "justify-content": "flex-start",
              "align-items": "center",
              "@media (max-width: 767px)": {
                "flex-wrap": "wrap"
              }
            },
            ".text-container": {
              "width": "57% !important",
              "& when not (@showIcon)": {
                "width": "100% !important"
              },
              "@media (max-width: 767px)": {
                "width": "100% !important"
              }
            },
            ".mbr-section-title": {
              "color": "#ffffff",
              "text-align": "left"
            },
            ".colored-text": {
              "line-height": "inherit",
              "font-weight": "inherit",
              "color": "inherit",
              "& when (@showColoredText)": {
                "color": "@coloredText"
              }
            },
            ".mbr-text": {
              "width": "68%",
              "margin-top": "1.2em",
              "color": "#000000",
              "@media (max-width: 991px)": {
                "width": "83%",
                "margin-top": "1rem"
              },
              "@media (max-width: 767px)": {
                "width": "100%"
              }
            },
            ".card-col": {
              "display": "flex",
              "width": "43% !important",
              "justify-content": "flex-start",
              "@media (max-width: 767px)": {
                "width": "100% !important",
                "justify-content": "center"
              }
            },
            ".card-wrapper": {
              "display": "flex",
              "margin-left": "8em",
              "justify-content": "flex-start",
              "@media (max-width: 991px)": {
                "margin-left": "1em"
              },
              "@media (max-width: 767px)": {
                "margin-top": "4em",
                "margin-left": "0",
                "justify-content": "center"
              }
            },
            ".card-box": {
              "display": "flex",
              "justify-content": "center",
              "align-items": "center",
              "max-width": "18em",
              "max-height": "18em",
              "width": "18em",
              "height": "18em",
              "border-radius": "50%",
              "background-color": "transparent",
              "position": "relative",
              ".bg-hover": {
                "position": "absolute",
                "border-radius": "50%",
                "top": "0",
                "left": "0",
                "width": "100%",
                "height": "100%",
                "background-color": "@iconBg",
                "transform": "scale(0)",
                "transition": ".5s all"
              },
              ".mbr-iconfont": {
                "position": "relative",
                "z-index": "100",
                "display": "block",
                "font-size": "6.5rem",
                "color": "#EE2524",
                "transition": ".5s all",
                "cursor": "pointer"
              },
              "&:hover": {
                ".bg-hover": {
                  "transform": "scale(1)"
                },
                ".mbr-iconfont": {
                  "transform": "rotate(-45deg)"
                }
              }
            },
            ".item-img": {
              "position": "absolute",
              "border-radius": "50%",
              "overflow": "hidden",
              "transition": ".5s all",
              "top": "1.5em",
              "left": "1.5em",
              "max-width": "15em",
              "max-height": "15em",
              "width": "100%",
              "height": "100%",
              "animation": "img-move 5s infinite linear both",
              "cursor": "pointer",
              "img": {
                "width": "100%",
                "height": "100%",
                "object-fit": "cover"
              }
            },
            "@keyframes img-move": {
              "0%": {
                "transform": "rotate(0deg)"
              },
              "25%": {
                "transform": "rotate(90deg)"
              },
              "50%": {
                "transform": "rotate(180deg)"
              },
              "75%": {
                "transform": "rotate(270deg)"
              },
              "100%": {
                "transform": "rotate(360deg)"
              }
            },
            ".mbr-text, .mbr-section-btn": {
              "color": "#ffffff"
            }
          },
          "_cid": "uLrKO3nRmz",
          "_anchor": "aheader1-6",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "overflow": "hidden",
            "@min-height": "90px",
            "@min-height-small": "@min-height / 2",
            "& when (@bg-type = \"color\")": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = \"image\")": {
              "background-image": "url(@bg-value)",
              "& when (@overlay)": {
                ".mbr-overlay": {
                  "background": "@overlayColor",
                  "opacity": "@overlayOpacity"
                }
              }
            },
            ".item:focus, span:focus": {
              "outline": "none"
            },
            ".container-fluid": {
              "padding-left": "0",
              "padding-right": "0",
              "overflow": "visible"
            },
            ".item": {
              "padding": "20px 0",
              "min-height": "@min-height",
              "@media (max-width: 768px)": {
                "min-height": "@min-height-small"
              }
            },
            ".content-wrap_1": {
              "transform": "rotate(2deg)",
              "background-color": "@contentBG_1"
            },
            ".content-wrap_2": {
              "transform": "rotate(-2deg)",
              "margin-top": "-3rem",
              "background-color": "@contentBG_2",
              "@media (max-width: 992px)": {
                "margin-top": "-1rem"
              }
            },
            ".container_1": {
              "background-color": "@contentBG_1",
              ".item_1": {
                "color": "@contentColor_1",
                "background-color": "@contentBG_1"
              }
            },
            ".container_2": {
              "background-color": "@contentBG_2",
              ".item_2": {
                "color": "@contentColor_2",
                "background-color": "@contentBG_2"
              }
            }
          },
          "_name": "features03",
          "_sourceTheme": "neuralm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"features03 neuralm5\" group=\"Features\" mbr-class=\"{'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <header>Animated Text Settings</header>\n        <select title=\"Font style\" name=\"linesTitle\">\n            <option value=\"title1\" selected>Title 1</option>\n            <option value=\"title2\">Title 2</option>\n        </select>\n        <input type=\"text\" title=\"Line content 1 <br> (For the best experience, please write at least 100 characters)\" inline=\"\" name=\"animatedLine1\" value=\"// Custom Exhaust Systems &amp; Headers // Suspension Arms &amp; Mounting Systems // Turbo/Supercharger Kits &amp; Piping // Performance Engine Components\">\n        <select title=\"Direction 1\" name=\"direction1\">\n            <option value=\"-1\">Left</option>\n            <option value=\"1\" selected>Right</option>\n        </select>\n        <input type=\"color\" title=\"Content Color 1\" value=\"#ffffff\" name=\"contentColor_1\" selected>\n        <input type=\"color\" title=\"Content BG 1\" value=\"#9f130f\" name=\"contentBG_1\" selected>\n        <input type=\"checkbox\" title=\"Line 2\" name=\"showLine2\" checked>\n        <input type=\"text\" title=\"Line content 2 <br> (For the best experience, please write at least 100 characters)\" inline=\"\" name=\"animatedLine2\" value=\"// Body Panel Fabrication &amp; Modifications // Custom Intake Manifolds &amp; Engine Mounts // Specialized Automotive Fabrication // Complete Performance Solutions\" condition=\"showLine2\">\n        <select title=\"Direction 2\" name=\"direction2\" condition=\"showLine2\">\n            <option value=\"-1\" selected>Left</option>\n            <option value=\"1\">Right</option>\n        </select>\n        <input type=\"color\" title=\"Content Color 2\" value=\"#ffffff\" name=\"contentColor_2\" selected condition=\"showLine2\">\n        <input type=\"color\" title=\"Content BG 2\" value=\"#121212\" name=\"contentBG_2\" selected condition=\"showLine2\">\n        <input type=\"range\" inline title=\"Line speed\" name=\"speed\" min=\"0.01\" max=\"0.09\" step=\"0.01\" value=\"0.02\">\n        <header>Background</header>\n        <fieldset type=\"background\" parallax name=\"bg\" required>\n            <input type=\"image\" title=\"Image\" value=\"@THEME_PATH@/components/_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#121212\" selected>\n        </fieldset>\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" checked condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#fff7ee\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.7\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n    </div>\n    <div class=\"container-fluid\">\n\n        <div class=\"content-wrap_1\">\n            <div class=\"loop-container container_1\">\n                <div class=\"item item_1\" mbr-class=\"{'display-1':linesTitle=='title1','display-2':linesTitle=='title2'}\" data-linewords=\"{{animatedLine1}}\" data-direction=\"{{direction1}}\" data-speed=\"{{speed}}\"></div>\n                <div class=\"item item_1\" mbr-class=\"{'display-1':linesTitle=='title1','display-2':linesTitle=='title2'}\" data-linewords=\"{{animatedLine1}}\" data-direction=\"{{direction1}}\" data-speed=\"{{speed}}\"></div>\n            </div>\n        </div>\n\n        <div class=\"content-wrap_2\" mbr-if=\"showLine2\">\n            <div class=\"loop-container container_2\">\n                <div class=\"item item_2\" mbr-class=\"{'display-1':linesTitle=='title1','display-2':linesTitle=='title2'}\" data-linewords=\"{{animatedLine2}}\" data-direction=\"{{direction2}}\" data-speed=\"{{speed}}\"></div>\n                <div class=\"item item_2\" mbr-class=\"{'display-1':linesTitle=='title1','display-2':linesTitle=='title2'}\" data-linewords=\"{{animatedLine2}}\" data-direction=\"{{direction2}}\" data-speed=\"{{speed}}\"></div>\n            </div>\n        </div>\n\n    </div>\n</section>",
          "_cid": "uGKLggbyjM",
          "_anchor": "features03-w",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".mbr-tag": {
              "margin-bottom": "16px",
              "color": "#adadad"
            },
            ".title-wrapper": {
              "@media (max-width: 992px)": {
                "margin-bottom": "40px"
              },
              ".mbr-section-title": {
                "margin-bottom": "40px",
                "@media (max-width: 992px)": {
                  "margin-bottom": "20px"
                }
              },
              ".text-wrapper": {
                ".mbr-text": {
                  "display": "inline-block",
                  "margin-bottom": "40px",
                  "@media (max-width: 992px)": {
                    "width": "100%",
                    "margin-bottom": "20px"
                  }
                }
              }
            },
            ".mbr-section-btn": {
              ".btn": {
                "&::after, &::before": {
                  "background-image": "linear-gradient(90deg, @gradient_1, @gradient_2 150%)"
                },
                "&:hover, &:focus": {
                  "&::after": {
                    "background-image": "linear-gradient(90deg, @gradient_1, @gradient_2 150%)",
                    "opacity": "1"
                  },
                  "color": "@activeBtn !important"
                }
              }
            },
            ".items-wrapper": {
              "margin": "0 -20px",
              ".item": {
                "padding": "0 20px",
                "margin-bottom": "40px",
                "@media (max-width: 992px)": {
                  "margin-bottom": "20px",
                  "&:last-child": {
                    "margin-bottom": "0"
                  }
                },
                "&:nth-child(2n)": {
                  "transform": "translateY(40px)",
                  "@media (max-width: 992px)": {
                    "transform": "none"
                  }
                },
                "&:hover, &:focus": {
                  ".item-wrapper .item-img .image-wrap img": {
                    "transform": "scale(1.06) translateX(0)"
                  }
                },
                ".item-wrapper": {
                  "position": "relative",
                  "height": "100%",
                  "border-radius": "0 !important",
                  ".item-img": {
                    "position": "relative",
                    "margin-bottom": "-40px",
                    ".image-wrap": {
                      "overflow": "hidden",
                      "img": {
                        "height": "315px",
                        "object-fit": "cover",
                        "transition": "all .3s ease",
                        "border-radius": "0 !important",
                        "transform": "scale(1.06) translateX(-8px)"
                      }
                    }
                  },
                  ".item-content": {
                    "padding": "80px 40px 40px 40px",
                    "border": "2px solid @border",
                    "@media (max-width: 992px)": {
                      "padding": "80px 20px 20px 20px"
                    },
                    ".item-name": {
                      "margin-bottom": "16px"
                    },
                    ".item-role": {
                      "margin-bottom": "0"
                    },
                    ".item-btn": {
                      "margin-top": "20px",
                      "@media (max-width: 992px)": {
                        "margin-bottom": "0"
                      },
                      ".btn": {
                        "padding": "17px 20px",
                        "margin-bottom": "0"
                      }
                    }
                  }
                }
              }
            },
            ".mbr-section-title": {
              "color": "#ffffff"
            },
            ".mbr-text": {
              "color": "#ffffff"
            },
            ".item-name": {
              "color": "#ffffff"
            },
            ".item-role": {
              "color": "#c7c7c7"
            },
            ".mbr-section-title, .main-btn": {
              "color": "#ffffff"
            }
          },
          "_name": "features07",
          "_sourceTheme": "neuralm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"features07 neuralm5\" group=\"Features\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"5\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"5\" condition=\"fullScreen == false\">\n        <input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Tag\" name=\"showTag\">\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <header>Cards</header>\n        <input type=\"checkbox\" title=\"Card Name\" name=\"showName\" checked>\n        <input type=\"checkbox\" title=\"Card Role\" name=\"showRole\" checked>\n        <input type=\"color\" title=\"Border Color\" value=\"#2c2c2c\" name=\"border\">\n        <header>Buttons</header>\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\" checked>\n        <input type=\"checkbox\" title=\"Card Buttons\" name=\"showCardButtons\">\n        <input type=\"color\" title=\"Button Gradient 1\" value=\"#9f130f\" name=\"gradient_1\" condition=\"showButtons || showCardButtons\" selected>\n        <input type=\"color\" title=\"Button Gradient 2\" value=\"#000000\" name=\"gradient_2\" condition=\"showButtons || showCardButtons\" selected>\n        <input type=\"color\" title=\"Button Active Color\" value=\"#ffffff\" name=\"activeBtn\" condition=\"showButtons || showCardButtons\" selected>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@THEME_PATH@/components/_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#121212\" selected>\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@THEME_PATH@/components/_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#121212\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row\" mbr-class=\"{'flex-row-reverse' : reverseContent}\">\n            <div class=\"col-12\">\n                <h3 class=\"mbr-tag mbr-fonts-style\" data-app-selector=\".mbr-tag\" mbr-theme-style=\"display-4\" mbr-if=\"showTag\">\n                    / <span>who?</span> /\n                </h3>\n            </div>\n            <div class=\"col-12 col-lg-5\">\n                <div class=\"title-wrapper\" mbr-if=\"showTitle\">\n                    <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title, .main-btn\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\">The Crew Behind the Craft</h2>\n                    <div class=\"text-wrapper\">\n                        <p class=\"mbr-text mbr-fonts-style\" data-app-selector=\".mbr-text, .text-wrapper\" mbr-theme-style=\"display-4\" mbr-if=\"showText\">At Spoolin Industries, founder and lead fabricator Mathew Johnson turns metal and tubing into pure performance. From hand-built turbo manifolds to one-off intercooler piping and everything in between, every weld he lays down is about strength, flow, and flawless fitment. Years on the tools—and a relentless eye for precision—mean your project leaves the shop lighter, tighter, and ready to make boost.<br><br>Whether you’re piecing together a street-driven sleeper or chasing podium finishes at the strip, Mathew crafts solutions that match your goals and budget, then ships Australia-wide so no build is out of reach. Ready for fabrication that does more than just look good? Book your spot with Spoolin Industries today.</p>\n                    </div>\n                    <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn main-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\"><a class=\"btn btn-white-outline\" href=\"index.html#gallery1-s\" data-app-placeholder=\"Type Text\">\n                            <span class=\"mobi-mbri mobi-mbri-arrow-next mbr-iconfont mbr-iconfont-btn\"></span>\n                            More info\n                        </a></div>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-6\">\n                <div class=\"row items-wrapper\">\n                    <div class=\"item features-image col-12 col-lg-6\">\n                        <div class=\"item-wrapper\">\n                            <div class=\"item-img\">\n                                <div class=\"image-wrap\">\n                                    <img src=\"@PROJECT_PATH@/assets/images/may-17-2025-08-24-12-pm.png-588x882.png\" alt=\"Spoolin Industries Founder\">\n                                </div>\n                            </div>\n                            <div class=\"item-content\">\n                                <h4 class=\"item-name mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showName\" data-app-selector=\".item-name, .item-btn\">Mathew Johnson&nbsp;</h4>\n                                <p class=\"item-role mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showRole\" data-app-selector=\".item-role\"><i>Founder &amp; Custom Fabrication Specialist</i></p>\n                                <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn item-btn\" mbr-if=\"showCardButtons\" data-toolbar=\"-mbrBtnMove\">\n                                    <a class=\"btn btn-white-outline\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                                        <span class=\"mobi-mbri mobi-mbri-arrow-next mbr-iconfont mbr-iconfont-btn\"></span>\n                                        Contacts\n                                    </a>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                    \n                    \n                    \n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "uGVRQLMXmV",
          "_anchor": "features07-1c",
          "_PHPplaceholders": [],
          "_JSplaceholders": [],
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "_name": "slider1",
          "_sourceTheme": "wellnessm5",
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "& when (@bg-type = \"color\")": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = \"image\")": {
              "background-image": "url(@bg-value)",
              "& when (@overlay)": {
                ".mbr-overlay": {
                  "background": "@overlayColor",
                  "opacity": "@overlayOpacity"
                }
              }
            },
            ".item": {
              "margin-right": "25px !imporant",
              "margin-left": "25px !imporant"
            },
            "img, .item-img": {
              "transition": "all 0.5s",
              "width": "100%"
            },
            ".item-img": {
              "height": "100%",
              "img": {
                "object-fit": "cover",
                "height": "100%"
              }
            },
            ".item:focus, span:focus": {
              "outline": "none"
            },
            ".item-wrapper": {
              "height": "100%",
              "position": "relative"
            },
            ".title-block": {
              "z-index": "99999",
              "min-width": "200px",
              "text-align": "center",
              "top": "90%",
              "left": "50%",
              "position": "absolute",
              "opacity": "0",
              "transform": "translate(-50%, -20%)",
              "transition": "700ms cubic-bezier(0.17, 0.67, 0, 1.01)"
            },
            ".mbr-text": {
              "color": "#977741"
            },
            ".mbr-section-subtitle": {
              "color": "#9a948d"
            },
            ".item-wrapper:hover": {
              ".title-block": {
                "opacity": "1",
                "transform": "translate(-50%, -50%)"
              },
              "img": {
                "filter": "brightness(100%) contrast(100%) saturate(100%) blur(0px) hue-rotate(0deg)",
                "box-shadow": "0 1px 15px 1px rgba(0, 0, 0, 0.9)",
                "opacity": "0.4"
              }
            },
            ".slide-content": {
              "position": "relative",
              "height": "100%",
              "display": "flex",
              "overflow": "hidden",
              "flex-flow": "column nowrap"
            },
            ".embla__slide": {
              "display": "flex",
              "justify-content": "center",
              "min-width": "38%",
              "max-width": "38%",
              "position": "relative",
              "@media (max-width: 768px)": {
                "min-width": "70%",
                "max-width": "initial",
                "margin-left": "1rem !important",
                "margin-right": "1rem !important"
              }
            },
            ".embla__button--next, .embla__button--prev": {
              "display": "flex"
            },
            ".embla__button": {
              "color": "@arrowsColor",
              "top": "50%",
              "width": "auto",
              "height": "auto",
              "margin-top": "-1.5rem",
              "font-size": "38px",
              "transition": "all 0.3s",
              "position": "absolute",
              "display": "flex",
              "justify-content": "center",
              "align-items": "center",
              "opacity": "0.5",
              "& when not (@arrows)": {
                ".mobi-mbri": {
                  "display": "none"
                }
              },
              "& when not (@arrowsMobile)": {
                "@media (max-width: 768px)": {
                  ".mobi-mbri": {
                    "display": "none"
                  }
                }
              },
              "&:hover": {
                "color": "#fff",
                "opacity": "1"
              },
              "&:disabled": {
                "cursor": "default",
                "display": "none"
              },
              "&.embla__button--prev": {
                "left": "0",
                "margin-left": "2.5rem",
                "@media (max-width: 768px)": {
                  "margin-left": "0.5rem"
                }
              },
              "&.embla__button--next": {
                "right": "0",
                "margin-right": "2.5rem",
                "@media (max-width: 768px)": {
                  "margin-right": "0.5rem"
                }
              },
              "background": "transparent !important",
              "border": "none !important",
              "padding": "0"
            },
            ".embla": {
              "position": "relative",
              "width": "100%"
            },
            ".embla__viewport": {
              "overflow": "hidden",
              "width": "100%"
            },
            ".embla__viewport.is-draggable": {
              "cursor": "grab"
            },
            ".embla__viewport.is-dragging": {
              "cursor": "grabbing"
            },
            ".embla__container": {
              "display": "flex",
              "user-select": "none",
              "-webkit-touch-callout": "none",
              "-khtml-user-select": "none",
              "-webkit-tap-highlight-color": "transparent"
            }
          },
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"slider1 mbr-embla\" group=\"Sliders & Galleries\" plugins=\"embla\" mbr-class=\"{'mbr-fullscreen': fullScreen,'mbr-parallax-background': bg.parallax}\">\n\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"3\" condition=\"!fullScreen\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"3\" condition=\"!fullScreen\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" name=\"showTitle\" title=\"Title\">\n        <input type=\"checkbox\" name=\"showSubtitle\" title=\"Subtitle\">\n        <header>Carousel</header>\n        <input type=\"checkbox\" title=\"Autoplay\" name=\"autoplay\" checked>\n        <input type=\"range\" title=\"Interval\" name=\"interval\" min=\"1\" max=\"10\" value=\"5\" step=\"1\" condition=\"autoplay\">\n        <input type=\"checkbox\" title=\"Loop\" name=\"loop\">\n        <input type=\"checkbox\" name=\"arrows\" title=\"Arrows\">\n        <input type=\"checkbox\" name=\"arrowsMobile\" title=\"Mobile Arrows\" condition=\"arrows\">\n        <input type=\"color\" title=\"Arrows Color\" name=\"arrowsColor\" value=\"#9f130f\" condition=\"arrows\">\n        <header>Cards</header>\n        <input type=\"checkbox\" name=\"showName\" title=\"Title\">\n        <input type=\"checkbox\" name=\"showText\" title=\"Text\">\n        <input type=\"range\" name=\"gap\" title=\"Gap\" min=\"0\" max=\"10\" step=\"1\" value=\"0\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@PROJECT_PATH@/assets/images/background1.jpg\" parallax>\n            <input type=\"color\" title=\"Color\" value=\"#121212\" selected>\n        </fieldset>\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#fafafa\" condition=\"overlay && bg.type == 'image'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.1\" condition=\"overlay && bg.type == 'image'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\"></div>\n    \n    <div class=\"position-relative text-center\">\n        <div class=\"mbr-section-head\" mbr-if=\"showTitle || showSubtitle\">\n            <h4 class=\"mbr-section-title mbr-fonts-style align-center mb-2\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title\">\n                WELLNESS SLIDER</h4>\n            <h5 class=\"mbr-section-subtitle mbr-fonts-style align-center mb-4\" mbr-theme-style=\"display-4\" mbr-if=\"showSubtitle\" data-app-selector=\".mbr-section-subtitle\">Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.</h5>\n        </div>\n        <div class=\"embla\" data-loop=\"{{loop}}\" data-auto-play=\"{{autoplay}}\" data-auto-play-interval=\"{{interval}}\" data-draggable=\"{{draggable}}\" data-skip-snaps=\"true\" data-align=\"center\" data-contain-scroll=\"trimSnaps\">\n            <div class=\"embla__viewport\" mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n                <div class=\"embla__container\">\n                    \n                    \n                    \n                    \n                    <div class=\"embla__slide slider-image item active\" mbr-style=\"{'margin-left': gap + 'rem', 'margin-right': gap + 'rem'}\">\n                        <div class=\"slide-content\">\n                            <div class=\"item-wrapper\">\n                                <div class=\"item-img\">\n                                    <img src=\"@PROJECT_PATH@/assets/images/481797469-17895531696171534-5489745502268849291-n-removebg-preview.png-576x433.png\" data-slide-to=\"0\" data-bs-slide-to=\"0\" alt>\n                                </div>\n                                <div class=\"title-block w-100\">\n                                    <p class=\"mbr-text mbr-fonts-style m-0\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".mbr-text\">\n                                        FOR BODY. FOR RELAX.</p>\n                                    <h3 class=\"mbr-fonts-style m-0\" mbr-theme-style=\"display-5\" mbr-if=\"showName\">\n                                        WELLNESS</h3>\n                                </div>\n                            </div>\n                        </div>\n                    </div><div class=\"embla__slide slider-image item active\" mbr-style=\"{'margin-left': gap + 'rem', 'margin-right': gap + 'rem'}\">\n                        <div class=\"slide-content\">\n                            <div class=\"item-wrapper\">\n                                <div class=\"item-img\">\n                                    <img src=\"@PROJECT_PATH@/assets/images/481128883-17895531711171534-4678607112213623033-n-removebg-preview-1.png-576x433.png\" data-slide-to=\"1\" data-bs-slide-to=\"1\">\n                                </div>\n                                <div class=\"title-block w-100\">\n                                    <p class=\"mbr-text mbr-fonts-style m-0\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".mbr-text\">\n                                        FOR BODY. FOR RELAX.</p>\n                                    <h3 class=\"mbr-fonts-style m-0\" mbr-theme-style=\"display-5\" mbr-if=\"showName\">\n                                        WELLNESS</h3>\n                                </div>\n                            </div>\n                        </div>\n                    </div><div class=\"embla__slide slider-image item active\" mbr-style=\"{'margin-left': gap + 'rem', 'margin-right': gap + 'rem'}\">\n                        <div class=\"slide-content\">\n                            <div class=\"item-wrapper\">\n                                <div class=\"item-img\">\n                                    <img src=\"@PROJECT_PATH@/assets/images/481093952-17895531729171534-3661082973361074393-n-removebg-preview.png-576x433.png\" data-slide-to=\"2\" data-bs-slide-to=\"2\">\n                                </div>\n                                <div class=\"title-block w-100\">\n                                    <p class=\"mbr-text mbr-fonts-style m-0\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".mbr-text\">\n                                        FOR BODY. FOR RELAX.</p>\n                                    <h3 class=\"mbr-fonts-style m-0\" mbr-theme-style=\"display-5\" mbr-if=\"showName\">\n                                        WELLNESS</h3>\n                                </div>\n                            </div>\n                        </div>\n                    </div><div class=\"embla__slide slider-image item active\" mbr-style=\"{'margin-left': gap + 'rem', 'margin-right': gap + 'rem'}\">\n                        <div class=\"slide-content\">\n                            <div class=\"item-wrapper\">\n                                <div class=\"item-img\">\n                                    <img src=\"@PROJECT_PATH@/assets/images/480831503-17895531714171534-2461564422834426193-n-removebg-preview.png-576x433.png\" data-slide-to=\"3\" data-bs-slide-to=\"3\">\n                                </div>\n                                <div class=\"title-block w-100\">\n                                    <p class=\"mbr-text mbr-fonts-style m-0\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".mbr-text\">\n                                        FOR BODY. FOR RELAX.</p>\n                                    <h3 class=\"mbr-fonts-style m-0\" mbr-theme-style=\"display-5\" mbr-if=\"showName\">\n                                        WELLNESS</h3>\n                                </div>\n                            </div>\n                        </div>\n                    </div><div class=\"embla__slide slider-image item active\" mbr-style=\"{'margin-left': gap + 'rem', 'margin-right': gap + 'rem'}\">\n                        <div class=\"slide-content\">\n                            <div class=\"item-wrapper\">\n                                <div class=\"item-img\">\n                                    <img src=\"@PROJECT_PATH@/assets/images/11111.png-1-500x500.png\" data-slide-to=\"4\" data-bs-slide-to=\"4\" alt>\n                                </div>\n                                <div class=\"title-block w-100\">\n                                    <p class=\"mbr-text mbr-fonts-style m-0\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".mbr-text\">\n                                        FOR BODY. FOR RELAX.</p>\n                                    <h3 class=\"mbr-fonts-style m-0\" mbr-theme-style=\"display-5\" mbr-if=\"showName\">\n                                        WELLNESS</h3>\n                                </div>\n                            </div>\n                        </div>\n                    </div><div class=\"embla__slide slider-image item active\" mbr-style=\"{'margin-left': gap + 'rem', 'margin-right': gap + 'rem'}\">\n                        <div class=\"slide-content\">\n                            <div class=\"item-wrapper\">\n                                <div class=\"item-img\">\n                                    <img src=\"@PROJECT_PATH@/assets/images/11111111.png-1-500x500.png\" data-slide-to=\"5\" data-bs-slide-to=\"5\" alt>\n                                </di