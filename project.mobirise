    "google-analytics": "<script type=\"application/ld+json\">\n{\n  \"@context\": \"https://schema.org\",\n  \"@type\": \"AutoRepair\",\n  \"name\": \"Spoolin Industries\",\n  \"image\": \"https://www.spoolinindustries.com.au/assets/og-cover.jpg\",\n  \"url\": \"https://www.spoolinindustries.com.au/\",\n  \"telephone\": \"+61 7 1234 5678\",\n  \"address\": {\n    \"@type\": \"PostalAddress\",\n    \"streetAddress\": \"12 Fabricator Dr\",\n    \"addressLocality\": \"Rockhampton\",\n    \"addressRegion\": \"QLD\",\n    \"postalCode\": \"4000\",\n    \"addressCountry\": \"AU\"\n  },\n  \"geo\": {\n    \"@type\": \"GeoCoordinates\",\n    \"latitude\": \"-27.4705\",\n    \"longitude\": \"153.0260\"\n  },\n  \"openingHoursSpecification\": [{\n    \"@type\": \"OpeningHoursSpecification\",\n    \"dayOfWeek\": [\"Monday\",\"Tuesday\",\"Wednesday\",\"Thursday\",\"Friday\"],\n    \"opens\": \"08:00\",\n    \"closes\": \"17:00\"\n  }],\n  \"sameAs\": [\n    \"https://www.facebook.com/spoolin-industries\",\n    \"https://www.instagram.com/spoolin-industries\"\n  ]\n}\n</script>",
