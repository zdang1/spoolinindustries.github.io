          "_customHTML": "<section mbr-id=\"_anchor\" class=\"_customHTML\">\n    \n    <mbr-parameters>\n    <!-- Block parameters controls (Blue \"Gear\" panel) -->\n        \n        <header>Select Divider</header>\n         <select title=\"Divider Type\" name=\"divType\">\n              <option value=\"Tri01\">Triangle 01</option>\n              <option value=\"Tri02\">Triangle 02</option>\n              <option value=\"Tri03\" selected>Triangle 03</option>\n              <option value=\"Tri04\">Triangle 04</option>\n              <option value=\"Tri05\">Triangle 05</option>\n         </select>\n        \n        <header>Divider Settings</header>\n        <input type=\"range\" inline title=\"Divider Height\" name=\"paddingBottom\" min=\"0\" max=\"8\" step=\"1\" value=\"3\">\n        <input type=\"color\" title=\"Background Color\" name=\"lineColor\" value=\"#121212\">\n        <input type=\"color\" title=\"Block Color\" name=\"bgColor\" value=\"#9f130f\">\n        \n         <select title=\"Line Style\" name=\"lineStyle\">\n           <option value=\"1\">Top</option>\n           <option value=\"2\" selected>Bottom</option>\n         </select>\n\t\t \n      <input type=\"checkbox\" title=\"Shadow\" name=\"blkShadow\" condition=\"divType !== 'Wave03'\">\n      <input type=\"color\" title=\"Shadow Color\" name=\"shadowColor\" value=\"#000000\" condition=\"blkShadow == '1'\">        \n        \n    <!-- End block parameters -->\n    </mbr-parameters> \n\n  \n<div mbr-if=\"divType == 'Tri01'\">        \n    <div class=\"custom-shape-divider\">\n    <svg data-name=\"Layer 1\" xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 1200 120\" preserveAspectRatio=\"none\">\n        <path d=\"M1200 0L0 0 598.97 114.72 1200 0z\" class=\"shape-fill\"></path>\n    </svg>\n    </div>\n</div>\n    \n    \n<div mbr-if=\"divType == 'Tri02'\">        \n    <div class=\"custom-shape-divider\">\n    <svg data-name=\"Layer 1\" xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 1200 120\" preserveAspectRatio=\"none\">\n        <path d=\"M1200 0L0 0 892.25 114.72 1200 0z\" class=\"shape-fill\"></path>\n    </svg>\n    </div>\n</div>\n    \n    \n<div mbr-if=\"divType == 'Tri03'\">        \n    <div class=\"custom-shape-divider\">\n    <svg data-name=\"Layer 1\" xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 1200 120\" preserveAspectRatio=\"none\">\n        <path d=\"M1200 0L0 0 892.25 114.72 1200 0z\" class=\"shape-fill\"></path>\n    </svg>\n    </div>\n</div>\n \n    \n<div mbr-if=\"divType == 'Tri04'\">        \n    <div class=\"custom-shape-divider\">\n    <svg xmlns=\"http://www.w3.org/2000/svg\" preserveAspectRatio=\"none\" viewBox=\"0 0 773.74 154.98\"><path class=\"shape-fill\" d=\"M0 0h773.74L386.87 77.5Z\"></path><path class=\"shape-fill\" d=\"m0 0 386.87 154.98L773.74 0Z\" opacity=\".66\"></path></svg>\n    </div>\n</div>  \n    \n\n<div mbr-if=\"divType == 'Tri05'\">        \n    <div class=\"custom-shape-divider\">\n    <svg data-name=\"Layer 1\" xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 1200 120\" preserveAspectRatio=\"none\">\n        <path d=\"M649.97 0L550.03 0 599.91 54.12 649.97 0z\" class=\"shape-fill\"></path>\n    </svg>\n    </div>\n</div>\n    \n\n</section>",
