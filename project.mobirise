                },
                "&:nth-child(2)": {
                  "left": "15px",
                  "top": "24px",
                  "transition": "all 0.15s"
                },
                "&:nth-child(3)": {
                  "left": "15px",
                  "top": "24px",
                  "transition": "all 0.15s"
                },
                "&:nth-child(4)": {
