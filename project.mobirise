=\".75\" d=\"M664.6 55.5L500 69.9 335.4 55.5 500 36l164.6 19.5z\" class=\"shape-fill\"></path><path opacity=\".5\" d=\"M1000 30.2V36L854.9 53.2 1000 65.9v9.8L779.3 56.4 1000 30.2z\" class=\"shape-fill\"></path><path opacity=\".5\" d=\"M1000 30.2V36L854.9 53.2 1000 65.9v9.8L779.3 56.4 1000 30.2z\" class=\"shape-fill\"></path><path opacity=\".5\" d=\"M1000 36v29.9L854.9 53.2 1000 36z\" class=\"shape-fill\"></path><path opacity=\".5\" d=\"M1000 36v29.9L854.9 53.2 1000 36z\" class=\"shape-fill\"></path><path opacity=\".75\" d=\"M1000 36v29.9L854.9 53.2 1000 36z\" class=\"shape-fill\"></path>\n</svg>\n    </div>\n</div>  \n    \n    \n    \n    \n    \n\n</section>",
          "_anchor": "patterns-2a",
          "_cid": "uPo799X55V",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "_customTemplate": true,
          "_afterNavbarItem": false,
          "_customHTML": "\n\n\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Spoolin Industries - Custom Fabrication Booking</title>\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin=\"\">\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&amp;display=swap\" rel=\"stylesheet\">\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            font-family: 'Inter', 'Segoe UI', system-ui, -apple-system, sans-serif;\n            background: #121212;\n            color: #ffffff;\n            min-height: 100vh;\n            padding: 0;\n            margin: 0;\n            overflow-x: hidden;\n        }\n\n        .wizard-container {\n            max-width: 1200px;\n            margin: 0 auto;\n            background: linear-gradient(145deg, #111111, #0a0a0a);\n            border-radius: 24px;\n            box-shadow: 0 32px 64px rgba(0, 0, 0, 0.8), \n                        0 0 0 1px rgba(159, 19, 15, 0.1);\n            overflow: hidden;\n            position: relative;\n            backdrop-filter: blur(20px);\n        }\n\n\n\n        .progress-container {\n            padding: 40px 60px;\n            background: transparent !important;\n            border-bottom: 1px solid rgba(159, 19, 15, 0.1);\n        }\n\n        .progress-bar {\n            display: grid;\n            grid-template-columns: repeat(4, 1fr);\n            gap: 20px;\n            margin-bottom: 30px;\n            position: relative;\n            background: transparent !important;\n        }\n\n        .progress-line {\n            position: absolute;\n            top: 32px;\n            left: 10%;\n            height: 3px;\n            background: transparent !important;\n            width: 80%;\n            border-radius: 10px;\n            overflow: hidden;\n        }\n\n        .progress-fill {\n            height: 100%;\n            background: linear-gradient(90deg, #9f130f, #ff3030, #9f130f);\n            border-radius: 10px;\n            transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);\n            width: 0%;\n            position: relative;\n            overflow: hidden;\n        }\n\n        .progress-fill::after {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: -100%;\n            width: 100%;\n            height: 100%;\n            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);\n            animation: shimmer 2s infinite;\n        }\n\n        @keyframes shimmer {\n            0% { left: -100%; }\n            100% { left: 100%; }\n        }\n\n        .step-indicator {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            text-align: center;\n            position: relative;\n            z-index: 2;\n            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n            cursor: pointer;\n        }\n\n        .step-indicator .step-circle {\n            width: 64px;\n            height: 64px;\n            border-radius: 50%;\n            background: linear-gradient(145deg, #1a1a1a, #2a2a2a);\n            border: 2px solid #333;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-weight: 700;\n            font-size: 1.2rem;\n            margin-bottom: 12px;\n            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n            position: relative;\n            overflow: hidden;\n        }\n\n        .step-indicator .step-circle::before {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            right: 0;\n            bottom: 0;\n            background: linear-gradient(45deg, transparent, rgba(159, 19, 15, 0.1), transparent);\n            transform: translateX(-100%);\n            transition: transform 0.6s ease;\n        }\n\n        .step-indicator:hover .step-circle::before {\n            transform: translateX(100%);\n        }\n\n        .step-indicator.active .step-circle {\n            background: linear-gradient(145deg, #9f130f, #c71610);\n            border-color: #ff3030;\n            transform: scale(1.1);\n            box-shadow: \n                0 8px 32px rgba(159, 19, 15, 0.4),\n                0 0 0 4px rgba(159, 19, 15, 0.1);\n        }\n\n        .step-indicator.completed .step-circle {\n            background: linear-gradient(145deg, #00aa44, #00cc55);\n            border-color: #00ff66;\n            box-shadow: \n                0 8px 32px rgba(0, 170, 68, 0.3),\n                0 0 0 4px rgba(0, 170, 68, 0.1);\n        }\n\n        .step-label {\n            font-size: 0.95rem;\n            font-weight: 600;\n            opacity: 0.6;\n            transition: all 0.3s ease;\n            letter-spacing: 0.5px;\n            text-transform: uppercase;\n        }\n\n        .step-indicator.active .step-label {\n            opacity: 1;\n            color: #9f130f;\n            transform: translateY(-2px);\n        }\n\n        .step-indicator.completed .step-label {\n            opacity: 0.8;\n            color: #00aa44;\n        }\n\n        .wizard-content {\n            padding: 60px;\n            min-height: 500px;\n            background: linear-gradient(145deg, #0a0a0a, #111111);\n        }\n\n        .step {\n            display: none;\n            animation: fadeInSlide 0.6s cubic-bezier(0.4, 0, 0.2, 1);\n        }\n\n        .step.active {\n            display: block;\n        }\n\n        @keyframes fadeInSlide {\n            from {\n                opacity: 0;\n                transform: translateY(20px) scale(0.98);\n            }\n            to {\n                opacity: 1;\n                transform: translateY(0) scale(1);\n            }\n        }\n\n        .step-title {\n            font-size: 2.4rem;\n            margin-bottom: 32px;\n            color: #ffffff;\n            font-weight: 700;\n            text-align: center;\n            position: relative;\n        }\n\n        .step-title::after {\n            content: '';\n            position: absolute;\n            bottom: -8px;\n            left: 50%;\n            transform: translateX(-50%);\n            width: 60px;\n            height: 3px;\n            background: linear-gradient(90deg, #9f130f, #ff3030);\n            border-radius: 2px;\n        }\n\n        .service-grid {\n            display: grid;\n            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));\n            gap: 24px;\n            margin-top: 40px;\n        }\n\n        .service-card {\n            background: linear-gradient(145deg, #161616, #0e0e0e);\n            border: 1px solid rgba(255, 255, 255, 0.08);\n            border-radius: 20px;\n            padding: 32px;\n            cursor: pointer;\n            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n            position: relative;\n            overflow: hidden;\n            backdrop-filter: blur(10px);\n            height: 200px;\n            display: flex;\n            flex-direction: column;\n            justify-content: space-between;\n        }\n\n        .service-card::before {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            right: 0;\n            bottom: 0;\n            background: linear-gradient(135deg, \n                rgba(159, 19, 15, 0.05) 0%, \n                transparent 30%, \n                transparent 70%, \n                rgba(159, 19, 15, 0.05) 100%);\n            opacity: 0;\n            transition: opacity 0.4s ease;\n        }\n\n        .service-card::after {\n            content: '';\n            position: absolute;\n            top: -50%;\n            left: -50%;\n            width: 200%;\n            height: 200%;\n            background: conic-gradient(\n                from 0deg,\n                transparent,\n                rgba(159, 19, 15, 0.1),\n                transparent,\n                rgba(159, 19, 15, 0.1),\n                transparent\n            );\n            opacity: 0;\n            animation: rotate 3s linear infinite;\n            transition: opacity 0.4s ease;\n        }\n\n        @keyframes rotate {\n            from { transform: rotate(0deg); }\n            to { transform: rotate(360deg); }\n        }\n\n        .service-card:hover::before,\n        .service-card:hover::after {\n            opacity: 1;\n        }\n\n        .service-card:hover {\n            transform: translateY(-8px) scale(1.02);\n            border-color: rgba(159, 19, 15, 0.3);\n            box-shadow: \n                0 20px 40px rgba(0, 0, 0, 0.4),\n                0 0 0 1px rgba(159, 19, 15, 0.2),\n                inset 0 1px 0 rgba(255, 255, 255, 0.1);\n        }\n\n        .service-card.selected {\n            border-color: #9f130f;\n            background: linear-gradient(145deg, #1a0e0e, #0f0606);\n            box-shadow: \n                0 16px 32px rgba(159, 19, 15, 0.3),\n                0 0 0 2px rgba(159, 19, 15, 0.5),\n                inset 0 1px 0 rgba(255, 255, 255, 0.1);\n            transform: translateY(-4px) scale(1.02);\n        }\n\n        .service-card.selected::before {\n            opacity: 0.8;\n        }\n\n        .service-card h3 {\n            color: #ffffff;\n            margin-bottom: 12px;\n            font-size: 1.4rem;\n            font-weight: 700;\n            position: relative;\n            z-index: 1;\n        }\n\n        .service-card.selected h3 {\n            color: #ff4444;\n        }\n\n        .service-card p {\n            color: rgba(255, 255, 255, 0.7);\n            line-height: 1.5;\n            font-size: 0.95rem;\n            position: relative;\n            z-index: 1;\n        }\n\n        .service-card.selected p {\n            color: rgba(255, 255, 255, 0.9);\n        }\n\n        .form-group {\n            margin-bottom: 32px;\n        }\n\n        .form-group label {\n            display: block;\n            margin-bottom: 12px;\n            font-weight: 600;\n            color: #ffffff;\n            font-size: 1rem;\n            letter-spacing: 0.5px;\n        }\n\n        .form-group input,\n        .form-group select,\n        .form-group textarea {\n            width: 100%;\n            padding: 18px 20px;\n            border: 1px solid rgba(255, 255, 255, 0.08);\n            border-radius: 12px;\n            background: linear-gradient(145deg, #161616, #0e0e0e);\n            color: #fff;\n            font-size: 1rem;\n            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n            backdrop-filter: blur(10px);\n        }\n\n        .form-group select option {\n            background: #161616;\n            color: #ffffff;\n            padding: 10px;\n        }\n\n        .form-group select option:hover {\n            background: #2a2a2a;\n        }\n\n        .form-group input::placeholder,\n        .form-group textarea::placeholder {\n            color: rgba(255, 255, 255, 0.4);\n        }\n\n        .form-group input:focus,\n        .form-group select:focus,\n        .form-group textarea:focus {\n            outline: none;\n            border-color: rgba(159, 19, 15, 0.5);\n            box-shadow: \n                0 0 0 3px rgba(159, 19, 15, 0.1),\n                0 4px 20px rgba(159, 19, 15, 0.2);\n            background: linear-gradient(145deg, #1a1a1a, #121212);\n            transform: translateY(-1px);\n        }\n\n        .form-group input:hover,\n        .form-group select:hover,\n        .form-group textarea:hover {\n            border-color: rgba(255, 255, 255, 0.15);\n        }\n\n        .form-row {\n            display: grid;\n            grid-template-columns: 1fr 1fr;\n            gap: 32px;\n        }\n\n        .budget-slider-container {\n            margin: 40px 0;\n            padding: 32px;\n            background: linear-gradient(145deg, #161616, #0e0e0e);\n            border: 1px solid rgba(255, 255, 255, 0.08);\n            border-radius: 20px;\n            backdrop-filter: blur(10px);\n        }\n\n        .budget-display {\n            text-align: center;\n            font-size: 3rem;\n            font-weight: 800;\n            color: #ffffff;\n            margin-bottom: 20px;\n            text-shadow: 0 0 20px rgba(159, 19, 15, 0.5);\n            position: relative;\n        }\n\n        .budget-display::after {\n            content: '';\n            position: absolute;\n            bottom: -8px;\n            left: 50%;\n            transform: translateX(-50%);\n            width: 80px;\n            height: 2px;\n            background: linear-gradient(90deg, transparent, #9f130f, transparent);\n        }\n\n        .budget-slider {\n            width: 100%;\n            height: 12px;\n            border-radius: 8px;\n            background: linear-gradient(90deg, #222, #333);\n            outline: none;\n            -webkit-appearance: none;\n            position: relative;\n            margin: 20px 0;\n            cursor: pointer;\n        }\n\n        .budget-slider::-webkit-slider-thumb {\n            -webkit-appearance: none;\n            appearance: none;\n            width: 32px;\n            height: 32px;\n            border-radius: 50%;\n            background: linear-gradient(145deg, #9f130f, #c71610);\n            cursor: pointer;\n            box-shadow: \n                0 0 20px rgba(159, 19, 15, 0.6),\n                0 4px 8px rgba(0, 0, 0, 0.3);\n            border: 2px solid #ff3030;\n            transition: all 0.3s ease;\n        }\n\n        .budget-slider::-webkit-slider-thumb:hover {\n            transform: scale(1.2);\n            box-shadow: \n                0 0 30px rgba(159, 19, 15, 0.8),\n                0 6px 12px rgba(0, 0, 0, 0.4);\n        }\n\n        .budget-slider::-moz-range-thumb {\n            width: 32px;\n            height: 32px;\n            border-radius: 50%;\n            background: linear-gradient(145deg, #9f130f, #c71610);\n            cursor: pointer;\n            border: 2px solid #ff3030;\n            box-shadow: \n                0 0 20px rgba(159, 19, 15, 0.6),\n                0 4px 8px rgba(0, 0, 0, 0.3);\n        }\n\n        .quote-summary {\n            background: linear-gradient(145deg, #3a3a3a, #2a2a2a);\n            border: 2px solid #9f130f;\n            border-radius: 15px;\n            padding: 25px;\n            margin-bottom: 20px;\n        }\n\n        .summary-item {\n            display: flex;\n            justify-content: space-between;\n            margin-bottom: 10px;\n            padding: 8px 0;\n            border-bottom: 1px solid #444;\n        }\n\n        .summary-item:last-child {\n            border-bottom: none;\n            font-weight: bold;\n            font-size: 1.1rem;\n            color: #9f130f;\n        }\n\n        .wizard-navigation {\n            padding: 40px 60px;\n            background: linear-gradient(145deg, #0a0a0a, #141414);\n            border-top: 1px solid rgba(159, 19, 15, 0.1);\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n        }\n\n        .btn {\n            padding: 16px 32px;\n            border: none;\n            border-radius: 12px;\n            font-size: 1rem;\n            font-weight: 700;\n            cursor: pointer;\n            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n            text-transform: uppercase;\n            letter-spacing: 1px;\n            position: relative;\n            overflow: hidden;\n            min-width: 140px;\n        }\n\n        .btn::before {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: -100%;\n            width: 100%;\n            height: 100%;\n            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);\n            transition: left 0.5s ease;\n        }\n\n        .btn:hover::before {\n            left: 100%;\n        }\n\n        .btn-primary {\n            background: linear-gradient(135deg, #9f130f 0%, #c71610 50%, #9f130f 100%);\n            color: white;\n            border: 1px solid rgba(199, 22, 16, 0.3);\n            box-shadow: 0 4px 20px rgba(159, 19, 15, 0.2);\n        }\n\n        .btn-primary:hover {\n            transform: translateY(-3px) scale(1.02);\n            box-shadow: \n                0 12px 35px rgba(159, 19, 15, 0.4),\n                0 0 0 1px rgba(199, 22, 16, 0.5);\n        }\n\n        .btn-primary:active {\n            transform: translateY(-1px) scale(1.01);\n        }\n\n        .btn-secondary {\n            background: linear-gradient(145deg, #2a2a2a, #1a1a1a);\n            color: white;\n            border: 1px solid rgba(255, 255, 255, 0.1);\n            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);\n        }\n\n        .btn-secondary:hover {\n            background: linear-gradient(145deg, #3a3a3a, #2a2a2a);\n            transform: translateY(-2px);\n            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);\n        }\n\n        .btn:disabled {\n            opacity: 0.4;\n            cursor: not-allowed;\n            transform: none !important;\n        }\n\n        .btn:disabled:hover::before {\n            left: -100% !important;\n        }\n\n        .error-message {\n            background: #e74c3c;\n            color: white;\n            padding: 15px;\n            border-radius: 10px;\n            margin: 15px 0;\n            display: none;\n            animation: shake 0.5s ease;\n        }\n\n        @keyframes shake {\n            0%, 100% { transform: translateX(0); }\n            25% { transform: translateX(-5px); }\n            75% { transform: translateX(5px); }\n        }\n\n        .success-message {\n            background: #2ecc71;\n            color: white;\n            padding: 20px;\n            border-radius: 15px;\n            text-align: center;\n            margin: 20px 0;\n        }\n\n        .confirmation-container {\n            text-align: center;\n            padding: 40px;\n        }\n\n        .confirmation-icon {\n            font-size: 5rem;\n            color: #2ecc71;\n            margin-bottom: 20px;\n        }\n\n        .reference-id {\n            background: linear-gradient(145deg, #3a3a3a, #2a2a2a);\n            border: 2px solid #9f130f;\n            border-radius: 15px;\n            padding: 20px;\n            margin: 20px 0;\n            font-family: monospace;\n            font-size: 1.2rem;\n            letter-spacing: 2px;\n        }\n\n        .loading-spinner {\n            display: none;\n            width: 40px;\n            height: 40px;\n            border: 4px solid #444;\n            border-top: 4px solid #9f130f;\n            border-radius: 50%;\n            animation: spin 1s linear infinite;\n            margin: 20px auto;\n        }\n\n        @keyframes spin {\n            0% { transform: rotate(0deg); }\n            100% { transform: rotate(360deg); }\n        }\n\n        @media (max-width: 768px) {\n            .wizard-container {\n                margin: 10px;\n                border-radius: 15px;\n            }\n\n            .wizard-title {\n                font-size: 2rem;\n            }\n\n            .service-grid {\n                grid-template-columns: 1fr;\n            }\n\n            .form-row {\n                grid-template-columns: 1fr;\n            }\n\n            .wizard-navigation {\n                flex-direction: column;\n                gap: 15px;\n            }\n\n            .step-label {\n                font-size: 0.7rem;\n            }\n        }\n\n        @media (max-width: 480px) {\n            .wizard-content {\n                padding: 20px;\n            }\n\n            .progress-container {\n                padding: 20px;\n            }\n\n            .wizard-header {\n                padding: 20px;\n            }\n\n            .wizard-title {\n                font-size: 1.5rem;\n            }\n        }\n    </style>\n\n\n    <div class=\"wizard-container\">\n\n\n        <div class=\"progress-container\">\n            <div class=\"progress-bar\">\n                <div class=\"progress-line\">\n                    <div class=\"progress-fill\" id=\"progressFill\"></div>\n                </div>\n                <div class=\"step-indicator active\" data-step=\"1\">\n                    <div class=\"step-circle\">1</div>\n                    <div class=\"step-label\">Service</div>\n                </div>\n                <div class=\"step-indicator\" data-step=\"2\">\n                    <div class=\"step-circle\">2</div>\n                    <div class=\"step-label\">Details</div>\n                </div>\n                <div class=\"step-indicator\" data-step=\"3\">\n                    <div class=\"step-circle\">3</div>\n                    <div class=\"step-label\">Contact</div>\n                </div>\n                <div class=\"step-indicator\" data-step=\"4\">\n                    <div class=\"step-circle\">4</div>\n                    <div class=\"step-label\">Review</div>\n                </div>\n            </div>\n        </div>\n\n        <div class=\"wizard-content\">\n            <!-- Step 1: Service Selection -->\n            <div class=\"step active\" id=\"step1\">\n                <h2 class=\"step-title\">Select Your Fabrication Service</h2>\n                <div class=\"service-grid\">\n                    <div class=\"service-card\" data-service=\"exhaust\">\n                        <h3>Custom Exhaust Systems</h3>\n                        <p>Performance exhaust systems tailored to your vehicle's specifications and your performance goals.</p>\n                    </div>\n                    <div class=\"service-card\" data-service=\"suspension\">\n                        <h3>Suspension Components</h3>\n                        <p>Custom suspension parts including arms, brackets, and mounting systems for improved handling.</p>\n                    </div>\n                    <div class=\"service-card\" data-service=\"turbo\">\n                        <h3>Turbo/Supercharger Kits</h3>\n                        <p>Complete forced induction systems with custom piping and mounting solutions.</p>\n                    </div>\n                    <div class=\"service-card\" data-service=\"body\">\n                        <h3>Body Modifications</h3>\n                        <p>Custom body panels and structural modifications for performance and safety.</p>\n                    </div>\n                    <div class=\"service-card\" data-service=\"engine\">\n                        <h3>Engine Components</h3>\n                        <p>Custom engine mounts, intake manifolds, and other performance engine components.</p>\n                    </div>\n                    <div class=\"service-card\" data-service=\"other\">\n                        <h3>Other Custom Work</h3>\n                        <p>Specialized fabrication services for unique automotive projects and modifications.</p>\n                    </div>\n                </div>\n            </div>\n\n            <!-- Step 2: Project Details -->\n            <div class=\"step\" id=\"step2\">\n                <h2 class=\"step-title\">Project Details</h2>\n                <div class=\"form-row\">\n                    <div class=\"form-group\">\n                        <label for=\"vehicleMake\">Vehicle Make</label>\n                        <input type=\"text\" id=\"vehicleMake\" placeholder=\"e.g., Nissan, Holden, Toyota\">\n                    </div>\n                    <div class=\"form-group\">\n                        <label for=\"vehicleModel\">Vehicle Model</label>\n                        <input type=\"text\" id=\"vehicleModel\" placeholder=\"e.g., Patrol, Colorado, Landcruiser\">\n                    </div>\n                </div>\n                <div class=\"form-group\">\n                    <label for=\"vehicleYear\">Year</label>\n                    <input type=\"number\" id=\"vehicleYear\" min=\"1980\" max=\"2025\" placeholder=\"2020\">\n                </div>\n                <div class=\"budget-slider-container\">\n                    <label>Project Budget</label>\n                    <div class=\"budget-display\" id=\"budgetDisplay\">$5,000</div>\n                    <input type=\"range\" id=\"budgetSlider\" class=\"budget-slider\" min=\"300\" max=\"50000\" step=\"100\" value=\"5000\">\n                </div>\n                <div class=\"form-group\">\n                    <label for=\"projectDescription\">Project Description</label>\n                    <textarea id=\"projectDescription\" rows=\"4\" placeholder=\"Please describe your project in detail, including any specific requirements or goals...\"></textarea>\n                </div>\n            </div>\n\n            <!-- Step 3: Contact Information -->\n            <div class=\"step\" id=\"step3\">\n                <h2 class=\"step-title\">Contact Information</h2>\n                <div class=\"form-row\">\n                    <div class=\"form-group\">\n                        <label for=\"firstName\">First Name</label>\n                        <input type=\"text\" id=\"firstName\" required=\"\">\n                    </div>\n                    <div class=\"form-group\">\n                        <label for=\"lastName\">Last Name</label>\n                        <input type=\"text\" id=\"lastName\" required=\"\">\n                    </div>\n                </div>\n                <div class=\"form-group\">\n                    <label for=\"email\">Email Address</label>\n                    <input type=\"email\" id=\"email\" required=\"\">\n                </div>\n                <div class=\"form-group\">\n                    <label for=\"phone\">Phone Number</label>\n                    <input type=\"tel\" id=\"phone\" required=\"\">\n                </div>\n                <div class=\"form-group\">\n                    <label for=\"contactPreference\">Preferred Contact Method</label>\n                    <select id=\"contactPreference\">\n                        <option value=\"email\">Email</option>\n                        <option value=\"phone\">Phone</option>\n                        <option value=\"text\">Text Message</option>\n                    </select>\n                </div>\n                <div class=\"form-group\">\n                    <label for=\"location\">Your Location (City, State)</label>\n                    <input type=\"text\" id=\"location\" placeholder=\"e.g., Los Angeles, CA\">\n                </div>\n            </div>\n\n            <!-- Step 4: Quote Review -->\n            <div class=\"step\" id=\"step4\">\n                <h2 class=\"step-title\">Review Your Quote Request</h2>\n                <div class=\"quote-summary\" id=\"quoteSummary\">\n                    <!-- Summary will be populated by JavaScript -->\n                </div>\n                <div class=\"loading-spinner\" id=\"loadingSpinner\"></div>\n            </div>\n\n            <!-- Confirmation -->\n            <div class=\"step\" id=\"confirmation\" style=\"display: none;\">\n                <div class=\"confirmation-container\">\n                    <div class=\"confirmation-icon\">✓</div>\n                    <h2>Quote Request Submitted Successfully!</h2>\n                    <p>Thank you for choosing Spoolin Industries. We've received your custom fabrication request.</p>\n                    <div class=\"reference-id\">\n                        Reference ID: <span id=\"referenceId\"></span>\n                    </div>\n                    <p>We'll contact you within 24-48 hours to discuss your project in detail.</p>\n                </div>\n            </div>\n\n            <div class=\"error-message\" id=\"errorMessage\"></div>\n        </div>\n\n        <div class=\"wizard-navigation\" id=\"navigation\">\n            <button class=\"btn btn-secondary\" id=\"prevBtn\" onclick=\"changeStep(-1)\">Previous</button>\n            <button class=\"btn btn-primary\" id=\"nextBtn\" onclick=\"changeStep(1)\">Next</button>\n        </div>\n    </div>\n\n    [JS_CODE_0]\n\n ",
          "_customCSS": "",
          "alias": "code-editor",
          "_tags": [
            "Extension"
          ],
          "_name": "pro.custom-html",
          "_sourceTheme": "neuralm5",
          "_anchor": "custom-html-21",
          "_PHPplaceholders": [],
          "_JSplaceholders": [
            "<script>\n        // Formspree Configuration - Ready to go!\n        const FORMSPREE_CONFIG = {\n            endpoint: 'https://formspree.io/f/xnnvldzb', // Your Formspree endpoint\n            email: 'spoolinindustries@outlook.com' // Where you want to receive emails\n        };\n\n        let currentStep = 1;\n        const totalSteps = 4;\n        let selectedService = '';\n        let formData = {};\n\n        // Service selection\n        document.querySelectorAll('.service-card').forEach(card => {\n            card.addEventListener('click', function() {\n                document.querySelectorAll('.service-card').forEach(c => c.classList.remove('selected'));\n                this.classList.add('selected');\n                selectedService = this.dataset.service;\n            });\n        });\n\n        // Budget slider\n        const budgetSlider = document.getElementById('budgetSlider');\n        const budgetDisplay = document.getElementById('budgetDisplay');\n\n        budgetSlider.addEventListener('input', function() {\n            const value = parseInt(this.value);\n            budgetDisplay.textContent = `$${value.toLocaleString()}`;\n        });\n\n        function updateProgress() {\n            const progressFill = document.getElementById('progressFill');\n            const percentage = ((currentStep - 1) / (totalSteps - 1)) * 100;\n            progressFill.style.width = percentage + '%';\n\n            // Update step indicators\n            document.querySelectorAll('.step-indicator').forEach((indicator, index) => {\n                const stepNumber = index + 1;\n                const circle = indicator.querySelector('.step-circle');\n                indicator.classList.remove('active', 'completed');\n                \n                if (stepNumber < currentStep) {\n                    indicator.classList.add('completed');\n                    circle.innerHTML = '✓';\n                } else if (stepNumber === currentStep) {\n                    indicator.classList.add('active');\n                    circle.innerHTML = stepNumber;\n                } else {\n                    circle.innerHTML = stepNumber;\n                }\n            });\n        }\n\n        function showError(message) {\n            const errorDiv = document.getElementById('errorMessage');\n            errorDiv.textContent = message;\n            errorDiv.style.display = 'block';\n            setTimeout(() => {\n                errorDiv.style.display = 'none';\n            }, 5000);\n        }\n\n        function validateStep(step) {\n            switch(step) {\n                case 1:\n                    if (!selectedService) {\n                        showError('Please select a fabrication service.');\n                        return false;\n                    }\n                    break;\n                case 2:\n                    const vehicleMake = document.getElementById('vehicleMake').value;\n                    const vehicleModel = document.getElementById('vehicleModel').value;\n                    const vehicleYear = document.getElementById('vehicleYear').value;\n                    const description = document.getElementById('projectDescription').value;\n\n                    if (!vehicleMake || !vehicleModel || !vehicleYear || !description) {\n                        showError('Please fill in all project details.');\n                        return false;\n                    }\n                    break;\n                case 3:\n                    const firstName = document.getElementById('firstName').value;\n                    const lastName = document.getElementById('lastName').value;\n                    const email = document.getElementById('email').value;\n                    const phone = document.getElementById('phone').value;\n                    const location = document.getElementById('location').value;\n\n                    if (!firstName || !lastName || !email || !phone || !location) {\n                        showError('Please fill in all contact information.');\n                        return false;\n                    }\n\n                    // Email validation\n                    const emailRegex = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;\n                    if (!emailRegex.test(email)) {\n                        showError('Please enter a valid email address.');\n                        return false;\n                    }\n                    break;\n            }\n            return true;\n        }\n\n        function collectFormData() {\n            formData = {\n                service: selectedService,\n                vehicleMake: document.getElementById('vehicleMake').value,\n                vehicleModel: document.getElementById('vehicleModel').value,\n                vehicleYear: document.getElementById('vehicleYear').value,\n                budget: document.getElementById('budgetSlider').value,\n                description: document.getElementById('projectDescription').value,\n                firstName: document.getElementById('firstName').value,\n                lastName: document.getElementById('lastName').value,\n                email: document.getElementById('email').value,\n                phone: document.getElementById('phone').value,\n                contactPreference: document.getElementById('contactPreference').value,\n                location: document.getElementById('location').value\n            };\n        }\n\n        function updateQuoteSummary() {\n            collectFormData();\n            const summary = document.getElementById('quoteSummary');\n            \n            const serviceNames = {\n                'exhaust': 'Custom Exhaust Systems',\n                'suspension': 'Suspension Components',\n                'turbo': 'Turbo/Supercharger Kits',\n                'body': 'Body Modifications',\n                'engine': 'Engine Components',\n                'other': 'Other Custom Work'\n            };\n\n            summary.innerHTML = `\n                <div class=\"summary-item\">\n                    <span>Service:</span>\n                    <span>${serviceNames[formData.service] || 'Not selected'}</span>\n                </div>\n                <div class=\"summary-item\">\n                    <span>Vehicle:</span>\n                    <span>${formData.vehicleYear} ${formData.vehicleMake} ${formData.vehicleModel}</span>\n                </div>\n                <div class=\"summary-item\">\n                    <span>Budget:</span>\n                    <span>$${parseInt(formData.budget).toLocaleString()}</span>\n                </div>\n                <div class=\"summary-item\">\n                    <span>Contact:</span>\n                    <span>${formData.firstName} ${formData.lastName}</span>\n                </div>\n                <div class=\"summary-item\">\n                    <span>Email:</span>\n                    <span>${formData.email}</span>\n                </div>\n                <div class=\"summary-item\">\n                    <span>Phone:</span>\n                    <span>${formData.phone}</span>\n                </div>\n                <div class=\"summary-item\">\n                    <span>Location:</span>\n                    <span>${formData.location}</span>\n                </div>\n            `;\n        }\n\n        function generateReferenceId() {\n            const timestamp = Date.now().toString(36);\n            const random = Math.random().toString(36).substr(2, 5);\n            return `SPL-${timestamp}-${random}`.toUpperCase();\n        }\n\n        function submitQuote() {\n            console.log('=== SUBMIT QUOTE FUNCTION CALLED ===');\n            \n            const loadingSpinner = document.getElementById('loadingSpinner');\n            const nextBtn = document.getElementById('nextBtn');\n            \n            console.log('Elements found:', {\n                loadingSpinner: !!loadingSpinner,\n                nextBtn: !!nextBtn\n            });\n            \n            if (loadingSpinner) loadingSpinner.style.display = 'block';\n            if (nextBtn) {\n                nextBtn.disabled = true;\n                nextBtn.textContent = 'Submitting...';\n            }\n\n            try {\n                console.log('Collecting form data...');\n                collectFormData();\n                const referenceId = generateReferenceId();\n                \n                console.log('Form data collected:', formData);\n                console.log('Generated reference ID:', referenceId);\n                \n                // Show confirmation immediately (simulate 2 second processing)\n                setTimeout(() => {\n                    console.log('Showing confirmation page...');\n                    document.getElementById('referenceId').textContent = referenceId;\n                    showStep('confirmation');\n                    document.getElementById('navigation').style.display = 'none';\n                    \n                    if (loadingSpinner) loadingSpinner.style.display = 'none';\n                    \n                    // Try to send email in background without blocking\n                    try {\n                        const serviceNames = {\n                            'exhaust': 'Custom Exhaust Systems',\n                            'suspension': 'Suspension Components',\n                            'turbo': 'Turbo/Supercharger Kits',\n                            'body': 'Body Modifications',\n                            'engine': 'Engine Components',\n                            'other': 'Other Custom Work'\n                        };\n\n                        const emailParams = {\n                            // Template variables that match your EmailJS template\n                            reference_id: referenceId,\n                            service_type: serviceNames[formData.service],\n                            service_price: `$${parseInt(formData.budget).toLocaleString()}`,\n                            customer_name: `${formData.firstName} ${formData.lastName}`,\n                            customer_email: formData.email,\n                            customer_phone: formData.phone,\n                            preferred_contact: formData.contactPreference,\n                            best_time: 'Business Hours', // You can add this field to your form if needed\n                            vehicle_info: `${formData.vehicleYear} ${formData.vehicleMake} ${formData.vehicleModel}`,\n                            budget: `$${parseInt(formData.budget).toLocaleString()}`,\n                            project_description: formData.description,\n                            submission_time: new Date().toLocaleString(),\n                            \n                            // Standard email fields\n                            to_email: 'spoolinindustries@outlook.com',\n                            reply_to: formData.email\n                        };\n\n                        // Send to Formspree - Much simpler!\n                        try {\n                            console.log('Sending to Formspree...');\n                            \n                            const submitData = new FormData();\n                            \n                            // Add all the form data\n                            submitData.append('reference_id', referenceId);\n                            submitData.append('service_type', serviceNames[formData.service]);\n                            submitData.append('customer_name', `${formData.firstName} ${formData.lastName}`);\n                            submitData.append('customer_email', formData.email);\n                            submitData.append('customer_phone', formData.phone);\n                            submitData.append('preferred_contact', formData.contactPreference);\n                            submitData.append('vehicle_info', `${formData.vehicleYear} ${formData.vehicleMake} ${formData.vehicleModel}`);\n                            submitData.append('budget', `$${parseInt(formData.budget).toLocaleString()}`);\n                            submitData.append('project_description', formData.description);\n                            submitData.append('location', formData.location);\n                            submitData.append('submission_time', new Date().toLocaleString());\n                            submitData.append('_replyto', formData.email); // Formspree reply-to\n                            submitData.append('_subject', `New Quote Request - ${referenceId}`);\n                            \n                            // Send to Formspree\n                            if (FORMSPREE_CONFIG.endpoint !== 'YOUR_FORMSPREE_ENDPOINT_HERE') {\n                                fetch(FORMSPREE_CONFIG.endpoint, {\n                                    method: 'POST',\n                                    body: submitData\n                                })\n                                .then(response => {\n                                    if (response.ok) {\n                                        console.log('✅ Email sent successfully via Formspree!');\n                                    } else {\n                                        console.log('⚠️ Formspree response:', response.status);\n                                    }\n                                })\n                                .catch(error => {\n                                    console.log('📧 Formspree error (non-blocking):', error);\n                                });\n                            } else {\n                                console.log('🔧 Formspree endpoint not configured yet');\n                                console.log('📧 Formspree Setup (Super Easy!):');\n                                console.log('1. Go to https://formspree.io');\n                                console.log('2. Sign up (free)');\n                                console.log('3. Create a new form');\n                                console.log('4. Copy your endpoint URL');\n                                console.log('5. Replace YOUR_FORMSPREE_ENDPOINT_HERE in the code');\n                            }\n                        } catch (error) {\n                            console.log('📧 Formspree error (non-blocking):', error);\n                        }\n                    } catch (emailError) {\n                        console.log('Email error (non-blocking):', emailError);\n                    }\n                }, 2000);\n                \n            } catch (error) {\n                console.error('Error in submitQuote:', error);\n                showError('There was an error submitting your quote. Please try again or contact us directly.');\n                if (nextBtn) {\n                    nextBtn.disabled = false;\n                    nextBtn.textContent = 'Submit Quote';\n                }\n                if (loadingSpinner) loadingSpinner.style.display = 'none';\n            }\n        }\n\n        function showStep(stepId) {\n            document.querySelectorAll('.step').forEach(step => {\n                step.classList.remove('active');\n                step.style.display = 'none';\n            });\n            \n            const targetStep = document.getElementById(stepId);\n            targetStep.style.display = 'block';\n            setTimeout(() => {\n                targetStep.classList.add('active');\n            }, 50);\n        }\n\n        function changeStep(direction) {\n            console.log('changeStep called with direction:', direction, 'currentStep:', currentStep);\n            \n            if (direction === 1) {\n                if (currentStep < totalSteps) {\n                    console.log('Validating step:', currentStep);\n                    if (!validateStep(currentStep)) {\n                        console.log('Validation failed for step:', currentStep);\n                        return;\n                    }\n                    \n                    if (currentStep === 4) {\n                        console.log('Calling submitQuote...');\n                        submitQuote();\n                        return;\n                    }\n                    \n                    currentStep++;\n                    showStep(`step${currentStep}`);\n                    \n                    if (currentStep === 4) {\n                        updateQuoteSummary();\n                        document.getElementById('nextBtn').textContent = 'Submit Quote';\n                    }\n                } else {\n                    // If we're already at step 4 and user clicks again, submit\n                    console.log('Already at final step, submitting...');\n                    submitQuote();\n                }\n            } else {\n                if (currentStep > 1) {\n                    currentStep--;\n                    showStep(`step${currentStep}`);\n                    document.getElementById('nextBtn').textContent = 'Next';\n                }\n            }\n            \n            updateProgress();\n            updateNavigationButtons();\n        }\n\n        function updateNavigationButtons() {\n            const prevBtn = document.getElementById('prevBtn');\n            const nextBtn = document.getElementById('nextBtn');\n            \n            prevBtn.style.display = currentStep === 1 ? 'none' : 'block';\n            \n            if (currentStep === totalSteps) {\n                nextBtn.textContent = 'Submit Quote';\n            } else {\n                nextBtn.textContent = 'Next';\n            }\n        }\n\n        // Initialize\n        updateProgress();\n        updateNavigationButtons();\n\n        // Add direct click handler for submit button\n        document.addEventListener('DOMContentLoaded', function() {\n            const nextBtn = document.getElementById('nextBtn');\n            if (nextBtn) {\n                nextBtn.addEventListener('click', function() {\n                    console.log('Next button clicked! Current step:', currentStep);\n                    changeStep(1);\n                });\n            }\n        });\n\n        // Add real-time validation feedback\n        document.querySelectorAll('input, select, textarea').forEach(element => {\n            element.addEventListener('blur', function() {\n                if (this.hasAttribute('required') && !this.value) {\n                    this.style.borderColor = '#e74c3c';\n                } else {\n                    this.style.borderColor = '#444';\n                }\n            });\n\n            element.addEventListener('input', function() {\n                if (this.style.borderColor === 'rgb(231, 76, 60)' && this.value) {\n                    this.style.borderColor = '#444';\n                }\n            });\n        });\n    </script>"
          ]
        },
        {
          "alias": "Barrys Dividers V3.00/components",
          "_isSecondary": true,
          "typeCompatible": "type",
          "_styles": {
            "padding-top": "45px",
            "padding-bottom": "(@paddingBottom * 15px)",
            "background-color": "@bgColor",
            "& when (@lineStyle = '1')": {
              ".custom-shape-divider": {
                "position": "absolute",
                "top": "0",
                "left": "0",
                "width": "100%",
                "overflow": "hidden",
                "line-height": "0"
              },
              ".custom-shape-divider svg": {
                "position": "relative",
                "display": "block",
                "width": "calc(100% + 1.3px)",
                "height": "40px",
                "& when (@divType = 'Pat01')": {
                  "height": "80px"
                },
                "& when (@divType = 'Pat02')": {
                  "height": "60px"
                }
              },
              ".custom-shape-divider .shape-fill": {
                "fill": "@lineColor",
                "& when (@blkShadow)": {
                  "filter": "drop-shadow(5px 5px 4px @shadowColor)"
                }
              }
            },
            "& when (@lineStyle = '2')": {
              ".custom-shape-divider": {
                "position": "absolute",
                "bottom": "0",
                "left": "0",
                "width": "100%",
                "overflow": "hidden",
                "line-height": "0",
                "transform": "rotate(180deg)"
              },
              ".custom-shape-divider svg": {
                "position": "relative",
                "display": "block",
                "width": "calc(100% + 1.3px)",
                "height": "40px",
                "& when (@divType = 'Pat01')": {
                  "height": "80px"
                },
                "& when (@divType = 'Pat02')": {
                  "height": "60px"
                }
              },
              ".custom-shape-divider .shape-fill": {
                "fill": "@lineColor",
                "& when (@blkShadow)": {
                  "filter": "drop-shadow(5px 5px 4px @shadowColor)"
                }
              }
            }
          },
          "_name": "patterns",
          "_sourceTheme": "neuralm5",
          "_customHTML": "<section mbr-id=\"_anchor\" class=\"_customHTML\">\n    \n    <mbr-parameters>\n    <!-- Block parameters controls (Blue \"Gear\" panel) -->\n        \n        <header>Select Divider</header>\n         <select title=\"Divider Type\" name=\"divType\">\n              <option value=\"Pat01\" selected>Pattern 01</option>\n              <option value=\"Pat02\">Pattern 02</option>\n              <option value=\"Pat03\">Pattern 03</option>\n         </select>\n        \n        <header>Divider Settings</header>\n        <input type=\"range\" inline title=\"Divider Height\" name=\"paddingBottom\" min=\"0\" max=\"8\" step=\"1\" value=\"3\">\n        <input type=\"color\" title=\"Background Color\" name=\"lineColor\" value=\"#121212\">\n        <input type=\"color\" title=\"Block Color\" name=\"bgColor\" value=\"#121212\">\n        \n         <select title=\"Line Style\" name=\"lineStyle\">\n           <option value=\"1\" selected>Top</option>\n           <option value=\"2\">Bottom</option>\n         </select>\n\t\t \n      <input type=\"checkbox\" title=\"Shadow\" name=\"blkShadow\" condition=\"divType !== 'Wave03'\">\n      <input type=\"color\" title=\"Shadow Color\" name=\"shadowColor\" value=\"#000000\" condition=\"blkShadow == '1'\">        \n        \n    <!-- End block parameters -->\n    </mbr-parameters> \n\n<div mbr-if=\"divType == 'Wave01'\">     \n    <div class=\"custom-shape-divider\">\n    <svg data-name=\"Layer 1\" xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 1200 120\" preserveAspectRatio=\"none\">\n        <path d=\"M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V0H0V27.35A600.21,600.21,0,0,0,321.39,56.44Z\" class=\"shape-fill\"></path>\n    </svg>\n    </div>\n</div>\n    \n    \n<div mbr-if=\"divType == 'Pat01'\">        \n    <div class=\"custom-shape-divider\">\n    <svg preserveAspectRatio=\"xMidYMax slice\" xmlns=\"http: