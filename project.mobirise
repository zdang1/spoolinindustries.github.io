3\" class=\"shape-fill\"></path><path d=\"M1549.4 44.8a10 10 0 01-10-10h20.2a10 10 0 01-10.2 10zM1549.4 24.8a10 10 0 0110.2 10h-20.3a10 10 0 0110.1-10z\" opacity=\".5\" class=\"shape-fill\"></path><path d=\"M1549.4 24.8a10 10 0 0110.2 10h-20.3a10 10 0 0110.1-10z\" opacity=\".3\" class=\"shape-fill\"></path><path d=\"M1549.4 24.8a10 10 0 0110.2 10h-20.3a10 10 0 0110.1-10z\" opacity=\".5\" class=\"shape-fill\"></path>\n        </svg>\n    </div>\n    </div> \n    \n  <div mbr-if=\"divType == 'Pat03'\">     \n    <div class=\"custom-shape-divider\">\n    <svg preserveAspectRatio=\"none\" xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 1000 100\"><path opacity=\".5\" d=\"M0 86.9V74.7l220.7-19.3L0 29.2V17.9l250 38-250 31z\" class=\"shape-fill\"></path><path opacity=\".5\" d=\"M0 74.7v-8.8l145.2-12.7L0 36v-6.8l220.7 26.2L0 74.7z\" class=\"shape-fill\"></path><path opacity=\".5\" d=\"M0 74.7v-8.8l145.2-12.7L0 36v-6.8l220.7 26.2L0 74.7z\" class=\"shape-fill\"></path><path opacity=\".5\" d=\"M0 65.9V36l145.2 17.2L0 65.9z\" class=\"shape-fill\"></path><path opacity=\".5\" d=\"M0 65.9V36l145.2 17.2L0 65.9z\" class=\"shape-fill\"></path><path opacity=\".75\" d=\"M0 65.9V36l145.2 17.2L0 65.9z\" class=\"shape-fill\"></path><path opacity=\".5\" d=\"M750 55.9l250-38v12.3L779.3 56.4 1000 75.7v11.2l-250-31zM500 18L250 56l250 31 250-31zM279.3 56.3L500 30.2l220.7 26.2L500 75.7z\" class=\"shape-fill\"></path><path d=\"M500 17.9l-250 38-250-38v-18h1000v18l-250 38-250-38z\" class=\"shape-fill\"></path><path d=\"M500 30.2L279.3 56.4 500 75.7l220.7-19.3zM335.4 55.5L500 36l164.6 19.5L500 70z\" opacity=\".5\" class=\"shape-fill\"></path><path d=\"M500 30.2L279.3 56.4 500 75.7l220.7-19.3zM335.4 55.5L500 36l164.6 19.5L500 70z\" opacity=\".5\" class=\"shape-fill\"></path><path opacity=\".5\" d=\"M664.6 55.5L500 69.9 335.4 55.5 500 36l164.6 19.5z\" class=\"shape-fill\"></path><path opacity=\".5\" d=\"M664.6 55.5L500 69.9 335.4 55.5 500 36l164.6 19.5z\" class=\"shape-fill\"></path><path opacity=\".75\" d=\"M664.6 55.5L500 69.9 335.4 55.5 500 36l164.6 19.5z\" class=\"shape-fill\"></path><path opacity=\".5\" d=\"M1000 30.2V36L854.9 53.2 1000 65.9v9.8L779.3 56.4 1000 30.2z\" class=\"shape-fill\"></path><path opacity=\".5\" d=\"M1000 30.2V36L854.9 53.2 1000 65.9v9.8L779.3 56.4 1000 30.2z\" class=\"shape-fill\"></path><path opacity=\".5\" d=\"M1000 36v29.9L854.9 53.2 1000 36z\" class=\"shape-fill\"></path><path opacity=\".5\" d=\"M1000 36v29.9L854.9 53.2 1000 36z\" class=\"shape-fill\"></path><path opacity=\".75\" d=\"M1000 36v29.9L854.9 53.2 1000 36z\" class=\"shape-fill\"></path>\n</svg>\n    </div>\n</div>  \n    \n    \n    \n    \n    \n\n</section>",
          "_cid": "uPo72J2EfN",
          "_anchor": "patterns-27",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".row": {
              "overflow": "hidden"
            },
            ".title-wrapper": {
              "margin-bottom": "40px",
              ".mbr-tag": {
                "margin-bottom": "16px"
              },
              ".mbr-section-title": {
                "margin-bottom": "0"
              }
            },
            ".mbr-section-btn": {
              ".btn": {
                "margin-top": "20px",
                "&::after, &::before": {
                  "background-image": "linear-gradient(90deg, @gradient_1, @gradient_2 150%)"
                },
                "&:hover, &:focus": {
                  "&::after": {
                    "background-image": "linear-gradient(90deg, @gradient_1, @gradient_2 150%)",
                    "opacity": "1"
                  },
                  "color": "@activeBtn !important"
                }
              }
            },
            ".embla__slide": {
              "display": "flex",
              "justify-content": "center",
              "position": "relative",
              "min-width": "500px",
              "max-width": "500px",
              "@media (max-width: 767px)": {
                "min-width": "100%",
                "max-width": "100%"
              },
              ".slide-content": {
                "width": "100%",
                ".item-wrapper": {
                  "display": "flex",
                  "justify-content": "space-between",
                  "height": "100%",
                  "@media (max-width: 992px)": {
                    "display": "block"
                  },
                  ".number-wrap": {
                    "position": "relative",
                    "z-index": "1",
                    ".item-number": {
                      "display": "inline-block",
                      "color": "transparent",
                      "-webkit-background-clip": "text",
                      "background-image": "linear-gradient(-90deg, @gradient_1, @gradient_2)",
                      "margin-bottom": "0",
                      "margin-right": "40px",
                      "-webkit-text-fill-color": "@number",
                      "-webkit-text-stroke": "2px transparent",
                      "-webkit-text-stroke-width": "4px",
                      "text-stroke": "2px transparent",
                      "writing-mode": "vertical-lr",
                      "transform": "rotate(180deg)",
                      "margin-left": "0",
                      "@media (max-width: 992px)": {
                        "margin-bottom": "20px",
                        "writing-mode": "inherit",
                        "transform": "none",
                        "background-image": "linear-gradient(90deg, @gradient_1, @gradient_2)"
                      }
                    }
                  },
                  ".card-box": {
                    "position": "relative",
                    "z-index": "1",
                    "width": "70%",
                    "@media (max-width: 992px)": {
                      "width": "100%"
                    },
                    ".item-title": {
                      "margin-bottom": "16px"
                    },
                    ".item-text": {
                      "margin-bottom": "0"
                    }
                  }
                }
              }
            },
            ".arrows-wrapper": {
              "position": "absolute",
              "top": "-5.5rem",
              "right": "0",
              "border-radius": "3rem",
              "display": "flex",
              "@media (max-width: 992px)": {
                "top": "0"
              },
              "&::before": {
                "content": "''",
                "position": "absolute",
                "inset": "0",
                "padding": "2px",
                "border-radius": "inherit !important",
                "-webkit-mask": "linear-gradient(#ffffff 0 0) content-box, linear-gradient(#ffffff 0 0)",
                "background-image": "linear-gradient(90deg, @gradient_1, @gradient_2)",
                "-webkit-mask-composite": "xor",
                "mask-composite": "exclude",
                "pointer-events": "none"
              }
            },
            ".embla__button--next, .embla__button--prev": {
              "display": "flex"
            },
            ".embla__button": {
              "width": "48px",
              "height": "48px",
              "margin-top": "0",
              "font-size": "16px",
              "background-color": "transparent !important",
              "color": "@arrowsColor !important",
              "border": "none !important",
              "transition": "all 0.3s",
              "display": "flex",
              "justify-content": "center",
              "align-items": "center",
              "opacity": "1 !important",
              "& when not (@arrows)": {
                "display": "none"
              },
              "& when not (@arrowsMobile)": {
                "@media (max-width: 768px)": {
                  "display": "none"
                }
              },
              "&:hover": {
                "color": "@active !important"
              },
              "&.embla__button--prev": {},
              "&.embla__button--next": {}
            },
            ".embla": {
              "position": "relative",
              "width": "100%",
              "overflow": "visible",
              "& when (@arrows)": {
                "@media (max-width: 992px)": {
                  "padding-top": "6rem"
                }
              }
            },
            ".embla__viewport": {
              "width": "100%",
              "margin-right": "1rem"
            },
            ".embla__viewport.is-draggable": {
              "cursor": "grab"
            },
            ".embla__viewport.is-dragging": {
              "cursor": "grabbing"
            },
            ".embla__container": {
              "display": "flex",
              "user-select": "none",
              "-webkit-touch-callout": "none",
              "-khtml-user-select": "none",
              "-webkit-tap-highlight-color": "transparent"
            },
            ".btn-wrapper": {
              "margin-top": "-10%"
            },
            ".mbr-section-title": {
              "color": "#ffffff"
            },
            ".mbr-tag": {
              "color": "#adadad"
            },
            ".item-title": {
              "color": "#ffffff"
            },
            ".item-text": {
              "color": "#c7c7c7"
            }
          },
          "_name": "slider02",
          "_sourceTheme": "neuralm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"slider02 mbr-embla neuralm5\" group=\"Sliders & Galleries\" plugins=\"embla\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Tag\" name=\"showTag\">\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <header>Carousel</header>\n        <input type=\"checkbox\" title=\"Autoplay\" name=\"autoplay\">\n        <input type=\"range\" title=\"Interval\" name=\"interval\" min=\"1\" max=\"10\" value=\"4\" step=\"1\" condition=\"autoplay\">\n        <input type=\"checkbox\" title=\"Loop\" name=\"loop\" checked>\n        <input type=\"checkbox\" title=\"Draggable\" name=\"draggable\" checked>\n        <input type=\"checkbox\" name=\"arrows\" title=\"Arrows\" checked>\n        <input type=\"checkbox\" name=\"arrowsMobile\" title=\"Mobile Arrows\" condition=\"arrows\" checked>\n        <input type=\"color\" title=\"Arrows Color\" value=\"#ffffff\" name=\"arrowsColor\" condition=\"arrows\" selected>\n        <input type=\"color\" title=\"Arrows Active Color\" value=\"#9f130f\" name=\"active\" condition=\"arrows\" selected>\n        <header>Cards</header>\n        <input type=\"range\" name=\"gap\" title=\"Gap\" min=\"1\" max=\"10\" step=\"1\" value=\"1\">\n        <input type=\"checkbox\" title=\"Card Number\" name=\"showNumber\" checked>\n        <input type=\"color\" title=\"Number Color\" value=\"#ffffff\" name=\"number\" condition=\"showNumber\" selected>\n        <input type=\"checkbox\" title=\"Card Title\" name=\"showCardTitle\" checked>\n        <input type=\"checkbox\" title=\"Card Text\" name=\"showText\" checked>\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showCardButtons\" checked>\n        <input type=\"color\" title=\"Button Active Color\" value=\"#ffffff\" name=\"activeBtn\" condition=\"showCardButtons\" selected>\n        <header>Gradient</header>\n        <input type=\"color\" title=\"Gradient 1\" value=\"#9f130f\" name=\"gradient_1\" condition=\"showCardButtons || arrows || showNumber\" selected>\n        <input type=\"color\" title=\"Gradient 2\" value=\"#000000\" name=\"gradient_2\" condition=\"showCardButtons || arrows || showNumber\" selected>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax required>\n            <input type=\"image\" title=\"Image\" value=\"@THEME_PATH@/components/_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#121212\" selected>\n        </fieldset>\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#121212\" condition=\"overlay && bg.type == 'image'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.1\" condition=\"overlay && bg.type == 'image'\">\n    </mbr-parameters>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row\">\n            <div class=\"col-12 col-lg-8 card\">\n                <div class=\"title-wrapper\" mbr-if=\"showTitle || showTag\">\n                    <h3 class=\"mbr-tag mbr-fonts-style\" data-app-selector=\".mbr-tag\" mbr-theme-style=\"display-4\" mbr-if=\"showTag\"></h3>\n                    <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title, .main-btn\" mbr-theme-style=\"display-1\" mbr-if=\"showTitle\"><b>5 Reasons to Choose Us</b></h2>\n                </div>\n            </div>\n            <div class=\"col-12\">\n                <div class=\"embla\" data-loop=\"{{loop}}\" data-auto-play=\"{{autoplay}}\" data-auto-play-interval=\"{{interval}}\" data-draggable=\"{{draggable}}\" data-skip-snaps=\"true\" data-align=\"center\" data-contain-scroll=\"trimSnaps\">\n                    <div class=\"embla__viewport\">\n                        <div class=\"embla__container\">\n                            <div class=\"embla__slide slider-image item features-without-image\" mbr-style=\"{'margin-left': gap + 'rem', 'margin-right': gap + 'rem'}\">\n                                <div class=\"slide-content\">\n                                    <div class=\"item-wrapper\">\n                                        <div class=\"number-wrap\">\n                                            <p class=\"item-number mbr-fonts-style\" mbr-theme-style=\"display-1\" mbr-if=\"showNumber\" data-app-selector=\".item-number, .number-wrap\">\n                                                <b>01</b>\n                                            </p>\n                                        </div>\n                                        <div class=\"card-box\">\n                                            <h4 class=\"item-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardTitle\" data-app-selector=\".item-title, .item-btn\">Welds That Win Shows and Races</h4>\n                                            <p class=\"item-text mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".item-text\">Our fabrication doesn’t just hold — it performs under pressure and looks good doing it.<br></p>\n                                            <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn item-btn\" mbr-if=\"showCardButtons\" data-toolbar=\"-mbrBtnMove\"><a class=\"btn btn-white-outline\" href=\"index.html#list01-15\" data-app-placeholder=\"Type Text\">\n                                                    <span class=\"mobi-mbri mobi-mbri-arrow-next mbr-iconfont mbr-iconfont-btn\"></span>\n                                                    View more\n                                                </a></div>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                            <div class=\"embla__slide slider-image item features-without-image\" mbr-style=\"{'margin-left': gap + 'rem', 'margin-right': gap + 'rem'}\">\n                                <div class=\"slide-content\">\n                                    <div class=\"item-wrapper\">\n                                        <div class=\"number-wrap\">\n                                            <p class=\"item-number mbr-fonts-style\" mbr-theme-style=\"display-1\" mbr-if=\"showNumber\" data-app-selector=\".item-number, .number-wrap\">\n                                                <b>02</b>\n                                            </p>\n                                        </div>\n                                        <div class=\"card-box\">\n                                            <h4 class=\"item-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardTitle\" data-app-selector=\".item-title, .item-btn\">Built by Car People, for Car People</h4>\n                                            <p class=\"item-text mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".item-text\">We live and breathe fabrication, tuning, and performance. No fluff — just real results from real enthusiasts.<br></p>\n                                            <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn item-btn\" mbr-if=\"showCardButtons\" data-toolbar=\"-mbrBtnMove\"><a class=\"btn btn-white-outline\" href=\"index.html#list01-15\" data-app-placeholder=\"Type Text\">\n                                                    <span class=\"mobi-mbri mobi-mbri-arrow-next mbr-iconfont mbr-iconfont-btn\"></span>\n                                                    View more\n                                                </a></div>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                            <div class=\"embla__slide slider-image item features-without-image\" mbr-style=\"{'margin-left': gap + 'rem', 'margin-right': gap + 'rem'}\">\n                                <div class=\"slide-content\">\n                                    <div class=\"item-wrapper\">\n                                        <div class=\"number-wrap\">\n                                            <p class=\"item-number mbr-fonts-style\" mbr-theme-style=\"display-1\" mbr-if=\"showNumber\" data-app-selector=\".item-number, .number-wrap\">\n                                                <b>03</b>\n                                            </p>\n                                        </div>\n                                        <div class=\"card-box\">\n                                            <h4 class=\"item-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardTitle\" data-app-selector=\".item-title, .item-btn\">No Guesswork, Just Quality</h4>\n                                            <p class=\"item-text mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".item-text\">With years of hands-on experience, we deliver consistent, precise work that you can trust the first time.<br><br></p>\n                                            <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn item-btn\" mbr-if=\"showCardButtons\" data-toolbar=\"-mbrBtnMove\"><a class=\"btn btn-white-outline\" href=\"index.html#list01-15\" data-app-placeholder=\"Type Text\">\n                                                    <span class=\"mobi-mbri mobi-mbri-arrow-next mbr-iconfont mbr-iconfont-btn\"></span>\n                                                    View more\n                                                </a></div>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                            <div class=\"embla__slide slider-image item features-without-image\" mbr-style=\"{'margin-left': gap + 'rem', 'margin-right': gap + 'rem'}\">\n                                <div class=\"slide-content\">\n                                    <div class=\"item-wrapper\">\n                                        <div class=\"number-wrap\">\n                                            <p class=\"item-number mbr-fonts-style\" mbr-theme-style=\"display-1\" mbr-if=\"showNumber\" data-app-selector=\".item-number, .number-wrap\">\n                                                <b>04</b>\n                                            </p>\n                                        </div>\n                                        <div class=\"card-box\">\n                                            <h4 class=\"item-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardTitle\" data-app-selector=\".item-title, .item-btn\">From Street to Strip to Shed</h4>\n                                            <p class=\"item-text mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".item-text\">Whether it’s a daily driver, a drag weapon, or a garage-built beast — we’ve got the tools, the skills, and the passion to bring it to life.<br></p>\n                                            <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn item-btn\" mbr-if=\"showCardButtons\" data-toolbar=\"-mbrBtnMove\"><a class=\"btn btn-white-outline\" href=\"index.html#list01-15\" data-app-placeholder=\"Type Text\">\n                                                    <span class=\"mobi-mbri mobi-mbri-arrow-next mbr-iconfont mbr-iconfont-btn\"></span>\n                                                    View more\n                                                </a></div>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                            <div class=\"embla__slide slider-image item features-without-image\" mbr-style=\"{'margin-left': gap + 'rem', 'margin-right': gap + 'rem'}\">\n                                <div class=\"slide-content\">\n                                    <div class=\"item-wrapper\">\n                                        <div class=\"number-wrap\">\n                                            <p class=\"item-number mbr-fonts-style\" mbr-theme-style=\"display-1\" mbr-if=\"showNumber\" data-app-selector=\".item-number, .number-wrap\">\n                                                <b>05</b>\n                                            </p>\n                                        </div>\n                                        <div class=\"card-box\">\n                                            <h4 class=\"item-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardTitle\" data-app-selector=\".item-title, .item-btn\">Custom Work That Fits — Not Off-the-Shelf</h4>\n                                            <p class=\"item-text mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".item-text\">Every project is tailored. From piping to roll cages, everything is built to suit your exact setup and specs.<br></p>\n                                            <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn item-btn\" mbr-if=\"showCardButtons\" data-toolbar=\"-mbrBtnMove\"><a class=\"btn btn-white-outline\" href=\"index.html#list01-15\" data-app-placeholder=\"Type Text\">\n                                                    <span class=\"mobi-mbri mobi-mbri-arrow-next mbr-iconfont mbr-iconfont-btn\"></span>\n                                                    View more\n                                                </a></div>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"arrows-wrapper\">\n                        <button class=\"embla__button embla__button--prev\">\n                            <span class=\"mobi-mbri mobi-mbri-arrow-prev mbr-iconfont\" aria-hidden=\"true\"></span>\n                            <span class=\"sr-only visually-hidden visually-hidden visually-hidden\">Previous</span>\n                        </button>\n                        <button class=\"embla__button embla__button--next\">\n                            <span class=\"mobi-mbri mobi-mbri-arrow-next mbr-iconfont\" aria-hidden=\"true\"></span>\n                            <span class=\"sr-only visually-hidden visually-hidden visually-hidden\">Next</span>\n                        </button>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "uGVS5r2zg8",
          "_anchor": "slider02-1h",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".title-wrapper": {
              ".mbr-section-title": {
                "margin-bottom": "64px",
                "@media (max-width: 992px)": {
                  "margin-bottom": "24px"
                }
              }
            },
            ".panel-group": {
              ".card": {
                "position": "relative",
                "padding": "48px 0",
                "background-color": "transparent",
                "border-bottom": "1px solid @border",
                "border-radius": "0 !important",
                "@media (max-width: 1440px)": {
                  "padding": "32px 0"
                },
                "@media (max-width: 992px)": {
                  "padding": "24px 0"
                },
                "&:first-child": {
                  "border-top": "1px solid @border"
                },
                ".card-header": {
                  "background-color": "transparent",
                  "border": "none",
                  "border-radius": "0",
                  "padding": "0",
                  ".panel-title": {
                    "display": "flex",
                    "justify-content": "space-between",
                    "align-items": "center",
                    "width": "100%",
                    ".panel-title-edit": {
                      "margin-bottom": "0"
                    },
                    ".icon-wrapper": {
                      "width": "64px",
                      "height": "64px",
                      "min-width": "64px",
                      "display": "inline-flex",
                      "align-items": "center",
                      "justify-content": "center",
                      "margin-left": "16px",
                      "transition": "all 0.3s ease-in-out",
                      "border-radius": "100%",
                      "background-color": "@iconBg",
                      ".mbr-iconfont": {
                        "font-size": "32px",
                        "transition": "all 0.3s ease-in-out",
                        "color": "@icon"
                      }
                    },
                    "&:not(.collapsed)": {
                      ".icon-wrapper": {
                        ".mbr-iconfont": {
                          "transform": "rotate(-45deg)"
                        }
                      }
                    }
                  }
                },
                ".panel-collapse": {
                  ".panel-body": {
                    "margin-top": "48px",
                    "@media (max-width: 1440px)": {
                      "margin-top": "32px"
                    },
                    "@media (max-width: 992px)": {
                      "margin-top": "24px"
                    },
                    ".panel-text": {
                      "display": "inline-flex",
                      "width": "50%",
                      "margin-bottom": "0",
                      "@media (max-width: 992px)": {
                        "margin-top": "24px",
                        "width": "100%"
                      }
                    }
                  }
                }
              }
            },
            ".mbr-section-title": {
              "color": "#ffffff"
            },
            ".panel-title-edit": {
              "color": "#ffffff"
            },
            ".panel-text": {
              "color": "#ffffff"
            }
          },
          "_name": "list01",
          "_sourceTheme": "cargom5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"list01 cargom5\" group=\"List\" plugins=\"mbr-switch-arrow, mobirise-icons2\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"5\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <header>List</header>\n        <select title=\"Amount\" name=\"cardAmount\">\n            <option value=\"1\">1</option>\n            <option value=\"2\">2</option>\n            <option value=\"3\">3</option>\n            <option value=\"4\">4</option>\n            <option value=\"5\">5</option>\n            <option value=\"6\" selected>6</option>\n        </select>\n        <input type=\"color\" title=\"Icon Color\" value=\"#ffffff\" name=\"icon\" selected>\n        <input type=\"color\" title=\"Icon Bg\" value=\"#cb2723\" name=\"iconBg\" selected>\n        <input type=\"color\" title=\"Border Color\" name=\"border\" value=\"#e5e5e5\" selected>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/cargom5/components/_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#121212\" selected>\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@ADDONS_PATH@/cargom5/components/_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row\">\n            <div class=\"col-12\">\n                <div class=\"title-wrapper\">\n                    <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\">\n                        <b>Answers to <br> Frequently Asked Questions</b>\n                    </h2>\n                </div>\n                <div id=\"bootstrap-accordion\" class=\"panel-group accordionStyles accordion\" role=\"tablist\" aria-multiselectable=\"true\">\n                    <div class=\"card\">\n                        <div class=\"card-header\" role=\"tab\" id=\"headingOne\">\n                            <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse1\" aria-expanded=\"false\" aria-controls=\"collapse1\">\n                                <h4 class=\"panel-title-edit mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".panel-title-edit\"><b>What types of fabrication work do you offer?</b></h4>\n                                <div class=\"icon-wrapper\">\n                                    <span class=\"sign mbr-iconfont mobi-mbri-plus mobi-mbri\"></span>\n                                </div>\n                            </a>\n                        </div>\n                        <div id=\"collapse1\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingOne\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                            <div class=\"panel-body\">\n                                <p class=\"panel-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">\n                                    We handle everything from custom piping, intercooler setups, and exhaust systems to full chassis modifications, roll cages, and structural reinforcements. If it’s metal and it moves, we can build it.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"card\" mbr-if=\"cardAmount > 1\">\n                        <div class=\"card-header\" role=\"tab\" id=\"headingTwo\">\n                            <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse2\" aria-expanded=\"false\" aria-controls=\"collapse2\">\n                                <h4 class=\"panel-title-edit mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".panel-title-edit\"><b>Can you build parts from scratch or modify existing ones?</b></h4>\n                                <div class=\"icon-wrapper\">\n                                    <span class=\"sign mbr-iconfont mobi-mbri-plus mobi-mbri\"></span>\n                                </div>\n                            </a>\n                        </div>\n                        <div id=\"collapse2\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingTwo\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                            <div class=\"panel-body\">\n                                <p class=\"panel-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">Yes to both. We can fabricate completely new components to suit your project or modify and improve your existing parts for better fit, strength, or performance.<br></p>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"card\" mbr-if=\"cardAmount > 2\">\n                        <div class=\"card-header\" role=\"tab\" id=\"headingThree\">\n                            <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse3\" aria-expanded=\"false\" aria-controls=\"collapse3\">\n                                <h4 class=\"panel-title-edit mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".panel-title-edit\"><b>Do I need to book in advance for fabrication work?</b></h4>\n                                <div class=\"icon-wrapper\">\n                                    <span class=\"sign mbr-iconfont mobi-mbri-plus mobi-mbri\"></span>\n                                </div>\n                            </a>\n                        </div>\n                        <div id=\"collapse3\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingThree\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                            <div class=\"panel-body\">\n                                <p class=\"panel-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">\n                                    Definitely — most jobs require a booking due to high demand. Reach out with what you need, and we’ll line up a time that suits your build schedule.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"card\" mbr-if=\"cardAmount > 3\">\n                        <div class=\"card-header\" role=\"tab\" id=\"headingFour\">\n                            <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse4\" aria-expanded=\"false\" aria-controls=\"collapse4\">\n                                <h4 class=\"panel-title-edit mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".panel-title-edit\"><b>What’s the turnaround time for custom jobs?</b></h4>\n                                <div class=\"icon-wrapper\">\n                                    <span class=\"sign mbr-iconfont mobi-mbri-plus mobi-mbri\"></span>\n                                </div>\n                            </a>\n                        </div>\n                        <div id=\"collapse4\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingFour\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                            <div class=\"panel-body\">\n                                <p class=\"panel-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">\n                                    It depends on the scope. Small jobs might be done within a few days, while full builds or complex setups can take a few weeks. We’ll give you a realistic timeframe upfront.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"card\" mbr-if=\"cardAmount > 4\">\n                        <div class=\"card-header\" role=\"tab\" id=\"headingFive\">\n                            <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse5\" aria-expanded=\"false\" aria-controls=\"collapse5\">\n                                <h4 class=\"panel-title-edit mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".panel-title-edit\"><b>Can you work with customer-supplied parts or designs?</b></h4>\n                                <div class=\"icon-wrapper\">\n                                    <span class=\"sign mbr-iconfont mobi-mbri-plus mobi-mbri\"></span>\n                                </div>\n                            </a>\n                        </div>\n                        <div id=\"collapse5\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingFive\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                            <div class=\"panel-body\">\n                                <p class=\"panel-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">\n                                    Absolutely. Whether you've got parts in-hand or a rough sketch of what you’re chasing, we can work with your materials and ideas to bring them to life.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"card\" mbr-if=\"cardAmount > 5\">\n                        <div class=\"card-header\" role=\"tab\" id=\"headingSix\">\n                            <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse6\" aria-expanded=\"false\" aria-controls=\"collapse6\">\n                                <h4 class=\"panel-title-edit mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".panel-title-edit\"><b>Is your work certified for motorsport or road use?</b></h4>\n                                <div class=\"icon-wrapper\">\n                                    <span class=\"sign mbr-iconfont mobi-mbri-plus mobi-mbri\"></span>\n                                </div>\n                            </a>\n                        </div>\n                        <div id=\"collapse6\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingSix\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                            <div class=\"panel-body\">\n                                <p class=\"panel-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text, .panel-body\">\n                                    We fabricate to high standards and can meet motorsport requirements. If certification is needed, let us know during booking and we’ll ensure everything complies with the relevant specs.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "uLJjk0DeaU",
          "_anchor": "list01-15",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "_name": "apeople5",
          "_sourceTheme": "shopm5",
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "background-color": "@bgColor",
            ".mbr-section-head": {
              "margin-bottom": "32px"
            },
            ".mbr-section-title": {
              "color": "#24262b"
            },
            ".mbr-section-subtitle": {
              "margin-top": "16px",
              "color": "#24262b"
            },
            ".card": {
              "display": "flex",
              "align-items": "center",
              "justify-content": "center",
              "transition": "all 0.3s",
              "padding": "2rem 3rem !important",
              "@media (max-width: 767px)": {
                "padding": "1rem !important"
              },
              "&:hover": {
                "transform": "translateY(-1rem)"
              },
              "img": {
                "max-width": "200px",
                "height": "auto"
              }
            }
          },
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"people5 shopm5\" group=\"People\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"1\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"1\">\n        <select title=\"Align\" name=\"contentAlign\">\n            <option value=\"justify-content-start\">Left</option>\n            <option value=\"justify-content-center\" selected>Center</option>\n            <option value=\"justify-content-end\">Right</option>\n        </select>\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\">\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubTitle\">\n        <input type=\"range\" inline title=\"Items\" name=\"items\" min=\"1\" max=\"12\" value=\"4\" step=\"1\">\n        <header>Background</header>\n        <input type=\"color\" title=\"Color\" name=\"bgColor\" value=\"#121212\">\n    </mbr-parameters>\n    <div class=\"images-container\" mbr-class=\"{'container-fluid':fullWidth, container:fullWidth==false}\">\n        <div class=\"mbr-section-head\">\n            <h3 class=\"mbr-section-title mbr-fonts-style align-center mb-0\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title\">\n                <b>Our Clients</b>\n            </h3>\n            <h4 class=\"mbr-section-subtitle mbr-fonts-style align-center mb-0\" mbr-theme-style=\"display-4\" mbr-if=\"showSubTitle\" data-app-selector=\".mbr-section-subtitle\">\n                For a better look, use pictures of the same size in this block.\n                elit\n            </h4>\n        </div>\n        <div class=\"row {{ contentAlign }}\">\n            <div class=\"card col-6 col-md-4 col-lg-2\">\n                <a href=\"index.html#top\"><img src=\"@PROJECT_PATH@/assets/images/e564d451be837b57-1192x710.png\" alt=\"Spoolin Industries\"></a>\n            </div>\n            <div class=\"card col-6 col-md-4 col-lg-2\" mbr-if=\"items > 1\">\n                <a href=\"https://tunedbychop.com.au\"><img src=\"@PROJECT_PATH@/assets/images/mediamodifier-design-1.png-1-329x90.png\" alt=\"Tuned by Chop Logo\"></a>\n            </div>\n            <div class=\"card col-6 col-md-4 col-lg-2\" mbr-if=\"items > 2\">\n                <a href=\"https://www.cqbincleaners.com.au\"><img src=\"@PROJECT_PATH@/assets/images/cq-shirts-329x263.png\" alt=\"CqBincleaners logo\"></a>\n            </div>\n            <div class=\"card col-6 col-md-4 col-lg-2\" mbr-if=\"items > 3\">\n                <a href=\"http://dangerfield.design\"><img src=\"@PROJECT_PATH@/assets/images/dangerfield-design-logo.png-320x320.png-320x320.png\" alt=\"Dangerous Designs\"></a>\n            </div>\n            <div class=\"card col-6 col-md-4 col-lg-2\" mbr-if=\"items > 4\">\n                <img src=\"@PROJECT_PATH@/assets/images/5.png\" alt=\"Mobirise Website Builder\">\n            </div>\n            <div class=\"card col-6 col-md-4 col-lg-2\" mbr-if=\"items > 5\">\n                <img src=\"@PROJECT_PATH@/assets/images/1-1.png\" alt=\"Mobirise Website Builder\">\n            </div>\n            <div class=\"card col-6 col-md-4 col-lg-2\" mbr-if=\"items > 6\">\n                <img src=\"@PROJECT_PATH@/assets/images/2-1.png\" alt=\"Mobirise Website Builder\">\n            </div>\n            <div class=\"card col-6 col-md-4 col-lg-2\" mbr-if=\"items > 7\">\n                <img src=\"@PROJECT_PATH@/assets/images/3-1.png\" alt=\"Mobirise Website Builder\">\n            </div>\n            <div class=\"card col-6 col-md-4 col-lg-2\" mbr-if=\"items > 8\">\n                <img src=\"@PROJECT_PATH@/assets/images/4-1.png\" alt=\"Mobirise Website Builder\">\n            </div>\n            <div class=\"card col-6 col-md-4 col-lg-2\" mbr-if=\"items > 9\">\n                <img src=\"@PROJECT_PATH@/assets/images/5.png\" alt=\"Mobirise Website Builder\">\n            </div>\n            <div class=\"card col-6 col-md-4 col-lg-2\" mbr-if=\"items > 10\">\n                <img src=\"@PROJECT_PATH@/assets/images/1-1.png\" alt=\"Mobirise Website Builder\">\n            </div>\n            <div class=\"card col-6 col-md-4 col-lg-2\" mbr-if=\"items > 11\">\n                <img src=\"@PROJECT_PATH@/assets/images/2-1.png\" alt=\"Mobirise Website Builder\">\n            </div>\n        </div>\n    </div>\n</section>",
          "_JSplaceholders": [],
          "_PHPplaceholders": [],
          "_anchor": "apeople5-k",
          "_isUserblock": true,
          "_cid": "uLs6izBcqO",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            "& when (@fullWidth)": {
              ".container-fluid": {
                "padding": "10px 8px"
              }
            },
            "@media (max-width: 992px)": {
              ".container": {
                "padding": "10px 8px"
              }
            },
            ".row": {
              "margin": "0",
              ".card": {
                "padding": "0",
                "&:nth-child(2n)": {
                  ".item-wrapper": {
                    "margin-right": "0"
                  }
                }
              }
            },
            ".item-wrapper": {
              "display": "flex",
              "align-items": "center",
              "padding": "50px 40px",
              "background-color": "@container",
              "border-radius": "25px",
              "margin-right": "16px",
              "height": "100%",
              "@media (max-width: 992px)": {
                "margin": "0 0 16px 0"
              },
              "@media (max-width: 768px)": {
                "padding": "50px 10px"
              },
              ".content-wrap": {
                "width": "100%",
                ".mbr-section-title": {
                  "margin-bottom": "50px",
                  "@media (max-width: 992px)": {
                    "margin-bottom": "30px"
                  }
                },
                ".mbr-link": {
                  "margin-bottom": "0"
                },
                ".mbr-desc": {
                  "margin-bottom": "0"
                },
                ".mbr-section-btn": {
                  "margin-top": "40px",
                  "@media (max-width: 992px)": {
                    "margin-top": "20px"
                  }
                }
              }
            },
            ".mbr-section-title": {
              "color": "#222222"
            },
            ".mbr-section-title, .mbr-section-btn": {
              "text-align": "center",
              "color": "#ffffff"
            },
            ".mbr-desc": {
              "color": "#ffffff",
              "text-align": "center"
            },
            ".mbr-link": {
              "text-align": "center",
              "color": "#ffffff"
            }
          },
          "_name": "contacts01",
          "_sourceTheme": "trackm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"contacts01 trackm5\" group=\"Image & Video\" plugins=\"PlayerVimeo\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"0\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"0\" condition=\"fullScreen == false\">\n        <header>Cards</header>\n        <input type=\"checkbox\" title=\"Card Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Card Description\" name=\"showDesc\" checked>\n        <input type=\"checkbox\" title=\"Card Buttons\" name=\"showButtons\" checked>\n        <input type=\"color\" title=\"Container BG\" value=\"#cb2723\" name=\"container\" selected>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/trackm5/components/_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#121212\" selected>\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@ADDONS_PATH@/trackm5/components/_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row\" mbr-class=\"{'flex-row-reverse' : reverseContent}\">\n            <div class=\"col-12 col-lg-6 card\">\n                <div class=\"item-wrapper\">\n                    <div class=\"content-wrap\">\n                        <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title, .mbr-section-btn\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\"> Email\n                        </h2>\n                        <p class=\"mbr-link mbr-fonts-style\" data-app-selector=\".mbr-link\" mbr-theme-style=\"display-5\"><a href=\"mailto:admin@spoolinindustries.com.au\" class=\"text-white text-primary\">admin@spoolinindustries.com.au</a></p>\n                        <p class=\"mbr-desc mbr-fonts-style\" data-app-selector=\".mbr-desc\" mbr-theme-style=\"display-5\" mbr-if=\"showDesc\">\n                            We will reply as soon as possible\n                        </p>\n                        <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\"><a class=\"btn btn-black\" href=\"mailto:admin@spoolinindustries.com.au\" data-app-placeholder=\"Type Text\">\n                                Send an email\n                            </a></div>\n                    </div>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-6 card\">\n                <div class=\"item-wrapper\">\n                    <div class=\"content-wrap\">\n                        <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title, .mbr-section-btn\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\"> Phone\n                        </h2>\n                        <p class=\"mbr-link mbr-fonts-style\" data-app-selector=\".mbr-link\" mbr-theme-style=\"display-5\"><a href=\"tel:0417 175 355\" class=\"text-white\">0417 175 355</a></p>\n                        <p class=\"mbr-desc mbr-fonts-style\" data-app-selector=\".mbr-desc\" mbr-theme-style=\"display-5\" mbr-if=\"showDesc\">8:00-21:00 mon-fri</p>\n                        <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\"><a class=\"btn btn-black\" href=\"tel:0417175355\" data-app-placeholder=\"Type Text\">\n                                Call us\n                            </a></div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "uLJgXa2pAr",
          "_anchor": "contacts01-14",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "_name": "afooter1",
          "_sourceTheme": "algom5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"footer1 algom5\" group=\"Footers\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" global once=\"footers\" mbr-class=\"{\n    'mbr-parallax-background': bg.parallax}\">\n\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Logo Size\" name=\"logoSize\" min=\"1\" max=\"3\" step=\"1\" value=\"2\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Logo\" name=\"showLogo\" checked>\n        <input type=\"range\" title=\"Logo Size\" inline name=\"logoSize\" min=\"3\" max=\"8\" step=\"0.1\" value=\"3\" condition=\"showLogo\">\n        <input type=\"checkbox\" title=\"Brand Name\" name=\"showBrand\">\n        <input type=\"checkbox\" title=\"Copyright\" name=\"showCopyright\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\">\n        <input type=\"checkbox\" title=\"Link Title\" name=\"showTitle\">\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\">\n        <input type=\"checkbox\" title=\"Social Title\" name=\"showSocialText\" checked>\n        <input type=\"checkbox\" title=\"Social\" name=\"showSocial\" checked>\n        <input type=\"color\" title=\"Social Color\" name=\"iconColor\" value=\"#FFFFFF\" condition=\"showSocial\">\n        <input type=\"range\" name=\"socialCount\" title=\"Social Count\" min=\"1\" max=\"4\" step=\"1\" value=\"2\" condition=\"showSocial\">\n        <input type=\"color\" title=\"Mobil Border Color\" name=\"borderColor\" value=\"#E1F5FF\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/algom5/components/_images/background2.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#121212\" selected>\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@ADDONS_PATH@/algom5/components/_images/background2.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#021041\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.5\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n    <div class=\"container\">\n        <div class=\"row\">\n            <div class=\"col-12\">\n                <div class=\"footer-main-container\">\n                    <div class=\"col-brand\">\n                        <div class=\"navbar-brand\" mbr-if=\"showLogo || showBrand\">\n                        <span mbr-if=\"showLogo\" class=\"navbar-logo\">\n                        <a href=\"index.html\">\n                            <img src=\"@PROJECT_PATH@/assets/images/e564d451be837b57-1192x710.png-108x64.png\" alt=\"spoolin industries\" mbr-style=\"{'height': logoSize + 'rem'}\">\n                        </a>\n                        </span>\n                            <span mbr-if=\"showBrand\" mbr-buttons mbr-theme-style=\"display-5\" class=\"navbar-caption-wrap\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd,-mbrBtnRemove,-iconFont\"><a class=\"navbar-caption text-white\" data-app-selector=\".navbar-caption\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\"></a></span>\n                        </div>\n                        <p class=\"mbr-text mbr-fonts-style copyright align-left\" mbr-theme-style=\"display-4\" data-app-selector=\".copyright\" data-app-placeholder=\"Type Text\" mbr-if=\"showCopyright\">\n                            © Copyright 2025 Spoolin Industries - All Rights Reserved\n                        </p>\n                        <p class=\"brand-text mbr-fonts-style align-left\" mbr-theme-style=\"display-4\" data-app-selector=\".brand-text\" data-app-placeholder=\"Type Text\" mbr-if=\"showText\">\n                            Ut consequat semper viverra nam libero justo. In pellentesque massa placerat duis ultricies\n                            lacus sed turpis. Risus nullam eget felis eget.\n                        </p>\n                    </div>\n                    <div class=\"footer-border\"></div>\n                    <div class=\"col-link1 col-link\">\n                        <h5 mbr-text class=\"mbr-section-subtitle mbr-fonts-style\" data-app-selector=\".mbr-section-subtitle\" mbr-theme-style=\"display-7\" mbr-if=\"showTitle\">\n                            <b>Product</b>\n                        </h5>\n                        <ul class=\"list mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".list\" data-multiline=\"true\" data-app-edit=\"full\" mbr-article>\n                            <li class=\"mbr-text item-wrap\" data-app-selector=\".list\"><a href=\"index.html#aheader1-6\" class=\"text-white text-primary\">Home</a></li>\n                            <li class=\"mbr-text item-wrap\" data-app-selector=\".list\">Our Work</li>\n                            <li class=\"mbr-text item-wrap\" data-app-selector=\".list\"><a href=\"index.html#features07-1c\" class=\"text-primary\">Team</a></li>\n                            <li class=\"mbr-text item-wrap\" data-app-selector=\".list\"><a href=\"index.html#aform1-x\" class=\"text-primary\">Services</a></li>\n                        </ul>\n                    </div>\n                    <div class=\"col-link2 col-link\">\n                        <h5 mbr-text class=\"mbr-section-subtitle mbr-section-subtitle-2 mbr-fonts-style\" data-app-selector=\".mbr-section-subtitle\" mbr-theme-style=\"display-7\" mbr-if=\"showTitle\">\n                            .\n                        </h5>\n                        <ul class=\"list mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".list\" data-multiline=\"true\" data-app-edit=\"full\" mbr-article>\n                            <li class=\"mbr-text item-wrap\" data-app-selector=\".list\"><br></li>\n                        </ul>\n                    </div>\n                    <div class=\"footer-border\"></div>\n                    <div class=\"social-container\">\n                        <p class=\"btn-text mbr-fonts-style align-left\" mbr-theme-style=\"display-4\" data-app-selector=\".btn-text\" data-app-placeholder=\"Type Text\"></p>\n                        <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\"><a class=\"btn btn-secondary\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">Back Top</a></div>\n                        <p class=\"social-text mbr-fonts-style align-left\" mbr-theme-style=\"display-4\" data-app-selector=\".social-text\" data-app-placeholder=\"Type Text\" mbr-if=\"showSocialText\">\n                            <b>Connect With Us</b>\n                        </p>\n                        <div class=\"social-row display-7\" mbr-if=\"showSocial\">\n                            <div class=\"soc-item\">\n                                <a href=\"https://www.facebook.com/people/Spoolin-Industries/61557442715086/\" target=\"_blank\">\n                                    <span mbr-icon class=\"mbr-iconfont socicon-facebook socicon\"></span>\n                                </a>\n                            </div>\n                            <div class=\"soc-item\" mbr-if=\"socialCount>1\">\n                                <a href=\"https://www.tiktok.com/@spoolinindustries\" target=\"_blank\">\n                                    <span mbr-icon class=\"mbr-iconfont socicon-tiktok socicon\"></span>\n                                </a>\n                            </div>\n                            <div class=\"soc-item\" mbr-if=\"socialCount>2\">\n                                <a href=\"https://twitter.com/mobirise\" target=\"_blank\">\n                                    <span mbr-icon class=\"mbr-iconfont socicon socicon-instagram\"></span>\n                                </a>\n                            </div>\n                            <div class=\"soc-item\" mbr-if=\"socialCount>3\">\n                                <a href=\"https://twitter.com/mobirise\" target=\"_blank\">\n                                    <span mbr-icon class=\"mbr-iconfont socicon socicon-instagram\"></span>\n                                </a>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
