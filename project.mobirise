          "_name": "triangles",
          "_sourceTheme": "neuralm5",
          "_customHTML": "<section mbr-id=\"_anchor\" class=\"_customHTML\">\n    \n    <mbr-parameters>\n    <!-- Block parameters controls (Blue \"Gear\" panel) -->\n        \n        <header>Select Divider</header>\n         <select title=\"Divider Type\" name=\"divType\">\n              <option value=\"Tri01\">Triangle 01</option>\n              <option value=\"Tri02\" selected>Triangle 02</option>\n              <option value=\"Tri03\">Triangle 03</option>\n              <option value=\"Tri04\">Triangle 04</option>\n              <option value=\"Tri05\">Triangle 05</option>\n         </select>\n        \n        <header>Divider Settings</header>\n        <input type=\"range\" inline title=\"Divider Height\" name=\"paddingBottom\" min=\"0\" max=\"8\" step=\"1\" value=\"3\">\n        <input type=\"color\" title=\"Background Color\" name=\"lineColor\" value=\"#121212\">\n        <input type=\"color\" title=\"Block Color\" name=\"bgColor\" value=\"#9f130f\">\n        \n         <select title=\"Line Style\" name=\"lineStyle\">\n           <option value=\"1\">Top</option>\n           <option value=\"2\" selected>Bottom</option>\n         </select>\n\t\t \n      <input type=\"checkbox\" title=\"Shadow\" name=\"blkShadow\" condition=\"divType !== 'Wave03'\">\n      <input type=\"color\" title=\"Shadow Color\" name=\"shadowColor\" value=\"#000000\" condition=\"blkShadow == '1'\">        \n        \n    <!-- End block parameters -->\n    </mbr-parameters> \n\n  \n<div mbr-if=\"divType == 'Tri01'\">        \n    <div class=\"custom-shape-divider\">\n    <svg data-name=\"Layer 1\" xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 1200 120\" preserveAspectRatio=\"none\">\n        <path d=\"M1200 0L0 0 598.97 114.72 1200 0z\" class=\"shape-fill\"></path>\n    </svg>\n    </div>\n</div>\n    \n    \n<div mbr-if=\"divType == 'Tri02'\">        \n    <div class=\"custom-shape-divider\">\n    <svg data-name=\"Layer 1\" xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 1200 120\" preserveAspectRatio=\"none\">\n        <path d=\"M1200 0L0 0 892.25 114.72 1200 0z\" class=\"shape-fill\"></path>\n    </svg>\n    </div>\n</div>\n    \n    \n<div mbr-if=\"divType == 'Tri03'\">        \n    <div class=\"custom-shape-divider\">\n    <svg data-name=\"Layer 1\" xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 1200 120\" preserveAspectRatio=\"none\">\n        <path d=\"M1200 0L0 0 892.25 114.72 1200 0z\" class=\"shape-fill\"></path>\n    </svg>\n    </div>\n</div>\n \n    \n<div mbr-if=\"divType == 'Tri04'\">        \n    <div class=\"custom-shape-divider\">\n    <svg xmlns=\"http://www.w3.org/2000/svg\" preserveAspectRatio=\"none\" viewBox=\"0 0 773.74 154.98\"><path class=\"shape-fill\" d=\"M0 0h773.74L386.87 77.5Z\"></path><path class=\"shape-fill\" d=\"m0 0 386.87 154.98L773.74 0Z\" opacity=\".66\"></path></svg>\n    </div>\n</div>  \n    \n\n<div mbr-if=\"divType == 'Tri05'\">        \n    <div class=\"custom-shape-divider\">\n    <svg data-name=\"Layer 1\" xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 1200 120\" preserveAspectRatio=\"none\">\n        <path d=\"M649.97 0L550.03 0 599.91 54.12 649.97 0z\" class=\"shape-fill\"></path>\n    </svg>\n    </div>\n</div>\n    \n\n</section>",
          "_anchor": "triangles-y",
          "_cid": "uLtrtdlxdU",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".embla__slide": {
              "display": "flex",
              "justify-content": "center",
              "position": "relative",
              "min-width": "100%",
              "max-width": "100%",
              "@media (max-width: 767px)": {
                "min-width": "100%",
                "max-width": "100%"
              },
              ".slide-content": {
                "width": "100%",
                ".item-wrapper": {
                  "height": "100%",
                  ".item-img": {
                    "img": {
                      "height": "485px",
                      "object-fit": "cover",
                      "border-radius": "0 !important",
                      "@media (max-width: 992px)": {
                        "height": "350px"
                      }
                    }
                  },
                  ".btn-wrap": {
                    "position": "absolute",
                    "bottom": "0",
                    "right": "0",
                    "padding": "20px 10px 0 30px",
                    "background-color": "@btnBg",
                    "border-radius": "25px 0 23px 0",
                    "z-index": "2",
                    "@media (max-width: 992px)": {
                      "padding": "10px 0 0 20px"
                    },
                    ".svg1": {
                      "position": "absolute",
                      "top": "-29px",
                      "right": "0",
                      "transform": "rotate(180deg)",
                      "width": "30px",
                      "path": {
                        "fill": "@btnBg"
                      }
                    },
                    ".svg2": {
                      "position": "absolute",
                      "transform": "rotate(180deg)",
                      "width": "30px",
                      "bottom": "0",
                      "left": "-29px",
                      "path": {
                        "fill": "@btnBg"
                      }
                    }
                  }
                }
              }
            },
            ".embla__button--next, .embla__button--prev": {
              "display": "flex"
            },
            ".embla__button": {
              "bottom": "0",
              "width": "60px",
              "height": "60px",
              "margin-top": "-1.5rem",
              "font-size": "18px",
              "background-color": "@arrowsBg !important",
              "color": "@arrowsColor !important",
              "border": "none !important",
              "transition": "all 0.3s",
              "position": "absolute",
              "display": "flex",
              "justify-content": "center",
              "align-items": "center",
              "opacity": "1 !important",
              "& when not (@arrows)": {
                "display": "none"
              },
              "& when not (@arrowsMobile)": {
                "@media (max-width: 768px)": {
                  "display": "none"
                }
              },
              "&:hover": {
                "color": "@active !important"
              },
              "&.embla__button--prev": {
                "left": "0",
                "bottom": "140px",
                "border-radius": "0 25px 0 0"
              },
              "&.embla__button--next": {
                "left": "0",
                "bottom": "80px",
                "border-radius": "0 0 25px 0"
              }
            },
            ".svg3": {
              "position": "absolute",
              "top": "255px",
              "left": "0",
              "transform": "rotate(-90deg)",
              "width": "30px",
              "path": {
                "fill": "@arrowsBg"
              },
              "@media (max-width: 992px)": {
                "top": "120px"
              }
            },
            ".svg4": {
              "position": "absolute",
              "width": "30px",
              "bottom": "50px",
              "left": "0",
              "path": {
                "fill": "@arrowsBg"
              }
            },
            ".embla": {
              "position": "relative",
              "width": "100%",
              "overflow": "hidden"
            },
            ".embla__viewport": {
              "width": "100%",
              "margin-right": "1rem"
            },
            ".embla__viewport.is-draggable": {
              "cursor": "grab"
            },
            ".embla__viewport.is-dragging": {
              "cursor": "grabbing"
            },
            ".embla__container": {
              "display": "flex",
              "user-select": "none",
              "-webkit-touch-callout": "none",
              "-khtml-user-select": "none",
              "-webkit-tap-highlight-color": "transparent"
            },
            ".item-menu-overlay": {
              "opacity": "0 !important"
            },
            ".mbr-section-btn": {
              ".btn": {
                "margin-bottom": "0",
                "&::after, &::before": {
                  "background-image": "linear-gradient(90deg, @gradient_1, @gradient_2 150%)"
                },
                "&:hover, &:focus": {
                  "&::after": {
                    "background-image": "linear-gradient(90deg, @gradient_1, @gradient_2 150%)",
                    "opacity": "1"
                  },
                  "color": "@activeBtn !important"
                }
              }
            }
          },
          "_name": "slider01",
          "_sourceTheme": "neuralm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"slider01 mbr-embla neuralm5\" group=\"Sliders &amp; Galleries\" plugins=\"embla\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked=\"\">\n        <input type=\"range\" inline=\"\" title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline=\"\" title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <header>Carousel</header>\n        <input type=\"checkbox\" title=\"Autoplay\" name=\"autoplay\" checked=\"\">\n        <input type=\"range\" title=\"Interval\" name=\"interval\" min=\"1\" max=\"10\" value=\"3\" step=\"1\" condition=\"autoplay\">\n        <input type=\"checkbox\" title=\"Loop\" name=\"loop\" checked=\"\">\n        <input type=\"checkbox\" title=\"Draggable\" name=\"draggable\" checked=\"\">\n        <input type=\"checkbox\" name=\"arrows\" title=\"Arrows\" checked=\"\">\n        <input type=\"checkbox\" name=\"arrowsMobile\" title=\"Mobile Arrows\" condition=\"arrows\" checked=\"\">\n        <input type=\"color\" title=\"Arrows Color\" value=\"#ffffff\" name=\"arrowsColor\" condition=\"arrows\" selected=\"\">\n        <input type=\"color\" title=\"Arrows BG\" value=\"#121212\" name=\"arrowsBg\" condition=\"arrows\" selected=\"\">\n        <input type=\"color\" title=\"Arrows Active Color\" value=\"#e24c4a\" name=\"active\" condition=\"arrows\" selected=\"\">\n        <header>Buttons</header>\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\">\n        <input type=\"color\" title=\"Button Gradient 1\" value=\"#386bb7\" name=\"gradient_1\" condition=\"showButtons\" selected=\"\">\n        <input type=\"color\" title=\"Button Gradient 2\" value=\"#e24c4a\" name=\"gradient_2\" condition=\"showButtons\" selected=\"\">\n        <input type=\"color\" title=\"Button Active Color\" value=\"#ffffff\" name=\"activeBtn\" condition=\"showButtons\" selected=\"\">\n        <input type=\"color\" title=\"Button BG\" value=\"#121212\" name=\"btnBg\" condition=\"showButtons\" selected=\"\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax=\"\" required=\"\">\n            <input type=\"image\" title=\"Image\" value=\"@THEME_PATH@/components/_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#121212\" selected=\"\">\n        </fieldset>\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked=\"\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#121212\" condition=\"overlay &amp;&amp; bg.type == 'image'\">\n        <input type=\"range\" inline=\"\" title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.1\" condition=\"overlay &amp;&amp; bg.type == 'image'\">\n    </mbr-parameters>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay &amp;&amp; bg.type !== 'color'\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row\">\n            <div class=\"col-12\">\n                <div class=\"embla\" data-loop=\"{{loop}}\" data-auto-play=\"{{autoplay}}\" data-auto-play-interval=\"{{interval}}\" data-draggable=\"{{draggable}}\" data-skip-snaps=\"true\" data-align=\"center\" data-contain-scroll=\"trimSnaps\">\n                    <div class=\"embla__viewport\">\n                        <div class=\"embla__container\">\n                            <div class=\"embla__slide slider-image item\" mbr-style=\"{'margin-left': gap + 'px', 'margin-right': gap + 'px'}\">\n                                <div class=\"slide-content\">\n                                    <div class=\"item-wrapper\">\n                                        <div class=\"item-img\">\n                                            <img src=\"@PROJECT_PATH@/assets/images/spoolin-industries-background-1.png-1536x1024.png\" alt=\"Spoolin Industries\">\n                                        </div>\n                                        <div class=\"btn-wrap\" mbr-if=\"showButtons\">\n                                            <svg class=\"svg1\" viewBox=\"0 0 100 100\">\n                                                <path d=\"m100,0H0v100C0,44.77,44.77,0,100,0Z\"></path>\n                                            </svg>\n                                            <div mbr-buttons=\"\" mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" data-toolbar=\"-mbrBtnMove\"><a class=\"btn btn-white-outline\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                                                    <span class=\"mobi-mbri mobi-mbri-arrow-next mbr-iconfont mbr-iconfont-btn\"></span><font face=\"Moririse2\"><span style=\"font-size: 16px;\">s</span></font>Start now\n                                                </a></div>\n                                            <svg class=\"svg2\" viewBox=\"0 0 100 100\">\n                                                <path d=\"m100,0H0v100C0,44.77,44.77,0,100,0Z\"></path>\n                                            </svg>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                            <div class=\"embla__slide slider-image item\" mbr-style=\"{'margin-left': gap + 'px', 'margin-right': gap + 'px'}\">\n                                <div class=\"slide-content\">\n                                    <div class=\"item-wrapper\">\n                                        <div class=\"item-img\">\n                                            <img src=\"@PROJECT_PATH@/assets/images/spoolin-industries-background-2.png-1536x1024.png\" alt=\"Spoolin Industries\">\n                                        </div>\n                                        <div class=\"btn-wrap\" mbr-if=\"showButtons\">\n                                            <svg class=\"svg1\" viewBox=\"0 0 100 100\">\n                                                <path d=\"m100,0H0v100C0,44.77,44.77,0,100,0Z\"></path>\n                                            </svg>\n                                            <div mbr-buttons=\"\" mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\">\n                                                <a class=\"btn btn-white-outline\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                                                    <span class=\"mobi-mbri mobi-mbri-arrow-next mbr-iconfont mbr-iconfont-btn\"></span>\n                                                    Start now\n                                                </a>\n                                            </div>\n                                            <svg class=\"svg2\" viewBox=\"0 0 100 100\">\n                                                <path d=\"m100,0H0v100C0,44.77,44.77,0,100,0Z\"></path>\n                                            </svg>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                            <div class=\"embla__slide slider-image item\" mbr-style=\"{'margin-left': gap + 'px', 'margin-right': gap + 'px'}\">\n                                <div class=\"slide-content\">\n                                    <div class=\"item-wrapper\">\n                                        <div class=\"item-img\">\n                                            <img src=\"@PROJECT_PATH@/assets/images/spoolin-industries-background-3.png-1536x1024.png\" alt=\"Spoolin Industries\">\n                                        </div>\n                                        <div class=\"btn-wrap\" mbr-if=\"showButtons\">\n                                            <svg class=\"svg1\" viewBox=\"0 0 100 100\">\n                                                <path d=\"m100,0H0v100C0,44.77,44.77,0,100,0Z\"></path>\n                                            </svg>\n                                            <div mbr-buttons=\"\" mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\">\n                                                <a class=\"btn btn-white-outline\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                                                    <span class=\"mobi-mbri mobi-mbri-arrow-next mbr-iconfont mbr-iconfont-btn\"></span>\n                                                    Start now\n                                                </a>\n                                            </div>\n                                            <svg class=\"svg2\" viewBox=\"0 0 100 100\">\n                                                <path d=\"m100,0H0v100C0,44.77,44.77,0,100,0Z\"></path>\n                                            </svg>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                    <svg class=\"svg3\" viewBox=\"0 0 100 100\">\n                        <path d=\"m100,0H0v100C0,44.77,44.77,0,100,0Z\"></path>\n                    </svg>\n                    <button class=\"embla__button embla__button--prev\">\n                        <span class=\"mobi-mbri mobi-mbri-arrow-prev mbr-iconfont\" aria-hidden=\"true\"></span>\n                        <span class=\"sr-only visually-hidden visually-hidden visually-hidden\">Previous</span>\n                    </button>\n                    <button class=\"embla__button embla__button--next\">\n                        <span class=\"mobi-mbri mobi-mbri-arrow-next mbr-iconfont\" aria-hidden=\"true\"></span>\n                        <span class=\"sr-only visually-hidden visually-hidden visually-hidden\">Next</span>\n                    </button>\n                    <svg class=\"svg4\" viewBox=\"0 0 100 100\">\n                        <path d=\"m100,0H0v100C0,44.77,44.77,0,100,0Z\"></path>\n                    </svg>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "uGVRWZidAh",
          "_anchor": "slider01-1e",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
